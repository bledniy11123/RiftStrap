<Window x:Class="RiftStrap.UI.Windows.PerformanceOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RiftStrap Performance"
        Width="240" Height="160"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Left="16" Top="16"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="14" ClipToBounds="True" BorderThickness="1" BorderBrush="#10FFFFFF">
        <Grid>
            <!-- Background gradient -->
            <Border CornerRadius="14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E6080808" Offset="0" />
                        <GradientStop Color="#E60A0A0E" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Subtle top glow -->
            <Border CornerRadius="14,14,0,0" Height="40" VerticalAlignment="Top" IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#06FFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel Margin="16,12">
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Image Source="pack://application:,,,/Resources/RiftLogo.png" Width="14" Height="14"
                           RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,7,0" />
                    <TextBlock Text="PERFORMANCE" FontSize="9" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center" />
                </StackPanel>

                <!-- FPS -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="FPS" FontSize="10" Foreground="#555555" VerticalAlignment="Center" />
                    <TextBlock x:Name="FpsText" Grid.Column="1" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA"
                               FontFamily="JetBrains Mono, Cascadia Code, Consolas" />
                </Grid>

                <!-- CPU -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CPU" FontSize="10" Foreground="#555555" VerticalAlignment="Center" />
                    <TextBlock x:Name="CpuText" Grid.Column="1" Text="--%" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA"
                               FontFamily="JetBrains Mono, Cascadia Code, Consolas" />
                </Grid>

                <!-- RAM -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="RAM" FontSize="10" Foreground="#555555" VerticalAlignment="Center" />
                    <TextBlock x:Name="RamText" Grid.Column="1" Text="-- MB" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA"
                               FontFamily="JetBrains Mono, Cascadia Code, Consolas" />
                </Grid>

                <!-- Ping -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="PING" FontSize="10" Foreground="#555555" VerticalAlignment="Center" />
                    <TextBlock x:Name="PingText" Grid.Column="1" Text="-- ms" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA"
                               FontFamily="JetBrains Mono, Cascadia Code, Consolas" />
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>

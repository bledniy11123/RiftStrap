<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ══════════════════════════════════════════════════════════
         RIFT MONO DESIGN SYSTEM
         Monochrome, glassmorphism, Apple HIG inspired
         ══════════════════════════════════════════════════════════ -->

    <!-- ── BACKGROUND COLORS ─────────────────────────────────── -->
    <Color x:Key="RiftBgPrimary">#FF0A0A0A</Color>
    <Color x:Key="RiftBgSecondary">#FF141414</Color>
    <Color x:Key="RiftBgTertiary">#FF1E1E1E</Color>
    <Color x:Key="RiftBgElevated">#FF242424</Color>
    <Color x:Key="RiftBgHover">#FF2A2A2A</Color>
    <Color x:Key="RiftBgPressed">#FF333333</Color>
    <Color x:Key="RiftBgGlass">#B8141414</Color>

    <!-- ── TEXT COLORS ────────────────────────────────────────── -->
    <Color x:Key="RiftTextPrimary">#FFFAFAFA</Color>
    <Color x:Key="RiftTextSecondary">#FFA0A0A0</Color>
    <Color x:Key="RiftTextTertiary">#FF666666</Color>
    <Color x:Key="RiftTextDisabled">#FF444444</Color>

    <!-- ── BORDER COLORS ──────────────────────────────────────── -->
    <Color x:Key="RiftBorderSubtle">#0FFFFFFF</Color>
    <Color x:Key="RiftBorderDefault">#1AFFFFFF</Color>
    <Color x:Key="RiftBorderHover">#33FFFFFF</Color>
    <Color x:Key="RiftBorderFocus">#66FFFFFF</Color>

    <!-- ── ACCENT (monochrome = white) ────────────────────────── -->
    <Color x:Key="RiftAccent">#FFFFFFFF</Color>
    <Color x:Key="RiftAccentHover">#D9FFFFFF</Color>
    <Color x:Key="RiftAccentPressed">#B3FFFFFF</Color>
    <Color x:Key="RiftAccentSubtle">#1AFFFFFF</Color>
    <Color x:Key="RiftAccentGlow">#1FFFFFFF</Color>

    <!-- ── SEMANTIC COLORS (muted, monochrome-friendly) ───────── -->
    <Color x:Key="RiftSuccess">#FF8A8A8A</Color>
    <Color x:Key="RiftWarning">#FF999999</Color>
    <Color x:Key="RiftError">#FFAAAAAA</Color>

    <!-- ── BRUSHES ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="RiftBgPrimaryBrush" Color="{StaticResource RiftBgPrimary}" />
    <SolidColorBrush x:Key="RiftBgSecondaryBrush" Color="{StaticResource RiftBgSecondary}" />
    <SolidColorBrush x:Key="RiftBgTertiaryBrush" Color="{StaticResource RiftBgTertiary}" />
    <SolidColorBrush x:Key="RiftBgElevatedBrush" Color="{StaticResource RiftBgElevated}" />
    <SolidColorBrush x:Key="RiftBgHoverBrush" Color="{StaticResource RiftBgHover}" />
    <SolidColorBrush x:Key="RiftBgGlassBrush" Color="{StaticResource RiftBgGlass}" />
    <SolidColorBrush x:Key="RiftTextPrimaryBrush" Color="{StaticResource RiftTextPrimary}" />
    <SolidColorBrush x:Key="RiftTextSecondaryBrush" Color="{StaticResource RiftTextSecondary}" />
    <SolidColorBrush x:Key="RiftTextTertiaryBrush" Color="{StaticResource RiftTextTertiary}" />
    <SolidColorBrush x:Key="RiftTextDisabledBrush" Color="{StaticResource RiftTextDisabled}" />
    <SolidColorBrush x:Key="RiftBorderSubtleBrush" Color="{StaticResource RiftBorderSubtle}" />
    <SolidColorBrush x:Key="RiftBorderDefaultBrush" Color="{StaticResource RiftBorderDefault}" />
    <SolidColorBrush x:Key="RiftBorderHoverBrush" Color="{StaticResource RiftBorderHover}" />
    <SolidColorBrush x:Key="RiftBorderFocusBrush" Color="{StaticResource RiftBorderFocus}" />
    <SolidColorBrush x:Key="RiftAccentBrush" Color="{StaticResource RiftAccent}" />
    <SolidColorBrush x:Key="RiftAccentHoverBrush" Color="{StaticResource RiftAccentHover}" />
    <SolidColorBrush x:Key="RiftAccentSubtleBrush" Color="{StaticResource RiftAccentSubtle}" />

    <!-- ── OVERRIDE WPF UI SYSTEM COLORS ──────────────────────── -->
    <!-- Background fills -->
    <Color x:Key="ApplicationBackgroundColor">#FF0A0A0A</Color>
    <Color x:Key="SolidBackgroundFillColorBase">#FF0A0A0A</Color>
    <Color x:Key="SolidBackgroundFillColorSecondary">#FF141414</Color>
    <Color x:Key="SolidBackgroundFillColorTertiary">#FF1E1E1E</Color>
    <Color x:Key="SolidBackgroundFillColorQuarternary">#FF242424</Color>
    <Color x:Key="LayerFillColorDefault">#0AFFFFFF</Color>
    <Color x:Key="LayerOnAcrylicFillColorDefault">#0AFFFFFF</Color>
    <Color x:Key="LayerOnMicaBaseAltFillColorDefault">#0AFFFFFF</Color>
    <Color x:Key="LayerOnMicaBaseAltFillColorSecondary">#08FFFFFF</Color>
    <Color x:Key="LayerOnMicaBaseAltFillColorTertiary">#FF141414</Color>

    <!-- Control fills -->
    <Color x:Key="ControlFillColorDefault">#0FFFFFFF</Color>
    <Color x:Key="ControlFillColorSecondary">#15FFFFFF</Color>
    <Color x:Key="ControlFillColorTertiary">#08FFFFFF</Color>
    <Color x:Key="ControlFillColorDisabled">#05FFFFFF</Color>
    <Color x:Key="ControlFillColorInputActive">#B8141414</Color>
    <Color x:Key="ControlStrongFillColorDefault">#9EFFFFFF</Color>
    <Color x:Key="ControlStrongFillColorDisabled">#3FFFFFFF</Color>
    <Color x:Key="SubtleFillColorTransparent">#00000000</Color>
    <Color x:Key="SubtleFillColorSecondary">#0FFFFFFF</Color>
    <Color x:Key="SubtleFillColorTertiary">#0AFFFFFF</Color>
    <Color x:Key="SubtleFillColorDisabled">#00000000</Color>
    <Color x:Key="ControlAltFillColorTransparent">#00000000</Color>
    <Color x:Key="ControlAltFillColorSecondary">#19000000</Color>
    <Color x:Key="ControlAltFillColorTertiary">#0BFFFFFF</Color>
    <Color x:Key="ControlAltFillColorQuarternary">#12FFFFFF</Color>
    <Color x:Key="ControlAltFillColorDisabled">#00000000</Color>
    <Color x:Key="ControlOnImageFillColorDefault">#B41C1C1C</Color>

    <!-- Text fills -->
    <Color x:Key="TextFillColorPrimary">#FFFAFAFA</Color>
    <Color x:Key="TextFillColorSecondary">#FFA0A0A0</Color>
    <Color x:Key="TextFillColorTertiary">#FF666666</Color>
    <Color x:Key="TextFillColorDisabled">#FF444444</Color>
    <Color x:Key="TextOnAccentFillColorPrimary">#FF0A0A0A</Color>
    <Color x:Key="TextOnAccentFillColorSecondary">#80000000</Color>
    <Color x:Key="TextOnAccentFillColorDisabled">#87000000</Color>
    <Color x:Key="TextOnAccentFillColorSelectedText">#FFFAFAFA</Color>
    <Color x:Key="AccentTextFillColorDisabled">#FF444444</Color>

    <!-- Control strokes -->
    <Color x:Key="ControlStrokeColorDefault">#12FFFFFF</Color>
    <Color x:Key="ControlStrokeColorSecondary">#0BFFFFFF</Color>
    <Color x:Key="ControlStrokeColorOnAccentDefault">#14000000</Color>
    <Color x:Key="ControlStrokeColorOnAccentSecondary">#24000000</Color>
    <Color x:Key="ControlStrokeColorOnAccentTertiary">#37000000</Color>
    <Color x:Key="ControlStrokeColorOnAccentDisabled">#33000000</Color>
    <Color x:Key="ControlStrokeColorForStrongFillWhenOnImage">#6B000000</Color>
    <Color x:Key="CardStrokeColorDefault">#15FFFFFF</Color>
    <Color x:Key="CardStrokeColorDefaultSolid">#FF1C1C1C</Color>
    <Color x:Key="ControlStrongStrokeColorDefault">#8BFFFFFF</Color>
    <Color x:Key="ControlStrongStrokeColorDisabled">#28FFFFFF</Color>
    <Color x:Key="SurfaceStrokeColorDefault">#66757575</Color>
    <Color x:Key="SurfaceStrokeColorFlyout">#33000000</Color>
    <Color x:Key="SurfaceStrokeColorInverse">#0FFFFFFF</Color>
    <Color x:Key="DividerStrokeColorDefault">#15FFFFFF</Color>
    <Color x:Key="FocusStrokeColorOuter">#FFFAFAFA</Color>
    <Color x:Key="FocusStrokeColorInner">#B3000000</Color>

    <!-- Accent colors (monochrome white) -->
    <Color x:Key="SystemAccentColor">#FFFFFFFF</Color>
    <Color x:Key="SystemAccentColorSecondary">#D9FFFFFF</Color>
    <Color x:Key="SystemAccentColorTertiary">#B3FFFFFF</Color>
    <Color x:Key="AccentFillColorSelectedTextBackground">#FFFFFFFF</Color>

    <!-- Flyout/popup -->
    <Color x:Key="FlyoutColor">#FF1E1E1E</Color>
    <Color x:Key="PopupBorderColor">#33FFFFFF</Color>

    <!-- ── BRUSH OVERRIDES (WPF UI controls use these) ────────── -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#FF0A0A0A" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#FF0A0A0A" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="#FF141414" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="#FF242424" />
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#0AFFFFFF" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#0FFFFFFF" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#15FFFFFF" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="#08FFFFFF" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="#05FFFFFF" />
    <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush" Color="#9EFFFFFF" />
    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="#00000000" />
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#0FFFFFFF" />
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#0AFFFFFF" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FFFAFAFA" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#FFA0A0A0" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#FF666666" />
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#FF444444" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#12FFFFFF" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="#0BFFFFFF" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#15FFFFFF" />
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="#15FFFFFF" />
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="#15FFFFFF" />
    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#D9FFFFFF" />
    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="#B3FFFFFF" />
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="#D9FFFFFF" />
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="#B3FFFFFF" />

    <!-- Scrollbar -->
    <Color x:Key="ScrollBarTrackFillColor">#00000000</Color>
    <Color x:Key="ScrollBarTrackStrokeColor">#00000000</Color>

    <!-- Text editor override -->
    <SolidColorBrush x:Key="NewTextEditorBackground" Color="#FF141414" />
    <SolidColorBrush x:Key="NewTextEditorForeground" Color="#FFFAFAFA" />
    <SolidColorBrush x:Key="NewTextEditorLink" Color="#FFFFFFFF" />

    <!-- ── CORNER RADII ───────────────────────────────────────── -->
    <CornerRadius x:Key="RiftCornerCard">12</CornerRadius>
    <CornerRadius x:Key="RiftCornerButton">8</CornerRadius>
    <CornerRadius x:Key="RiftCornerInput">6</CornerRadius>
    <CornerRadius x:Key="RiftCornerSmall">4</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="NavigationViewItemCornerRadius">8</CornerRadius>

    <!-- ── SPACING / THICKNESS ────────────────────────────────── -->
    <Thickness x:Key="RiftPaddingCard">16</Thickness>
    <Thickness x:Key="RiftPaddingSection">24</Thickness>
    <Thickness x:Key="RiftMarginItem">0,0,0,8</Thickness>
    <Thickness x:Key="RiftBorderThickness">1</Thickness>

    <!-- ── TYPOGRAPHY ─────────────────────────────────────────── -->
    <FontFamily x:Key="RiftFontPrimary">Inter, Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="RiftFontMono">JetBrains Mono, Cascadia Code, Consolas</FontFamily>
    <system:Double x:Key="RiftFontSizeCaption">11</system:Double>
    <system:Double x:Key="RiftFontSizeBody">13</system:Double>
    <system:Double x:Key="RiftFontSizeSubtitle">16</system:Double>
    <system:Double x:Key="RiftFontSizeTitle">22</system:Double>
    <system:Double x:Key="RiftFontSizeDisplay">32</system:Double>

    <!-- ── ANIMATION DURATIONS ────────────────────────────────── -->
    <Duration x:Key="RiftAnimFast">0:0:0.15</Duration>
    <Duration x:Key="RiftAnimNormal">0:0:0.25</Duration>
    <Duration x:Key="RiftAnimSlow">0:0:0.4</Duration>

    <!-- ── EASING FUNCTIONS ───────────────────────────────────── -->
    <!-- Apple-style decelerate curve -->
    <CubicEase x:Key="RiftEaseOut" EasingMode="EaseOut" />
    <CubicEase x:Key="RiftEaseInOut" EasingMode="EaseInOut" />
    <ExponentialEase x:Key="RiftEaseDecelerate" Exponent="7" EasingMode="EaseOut" />
    <!-- For SplineDoubleKeyFrame: KeySpline="0.22,1 0.36,1" -->

    <!-- ── NAVIGATION ITEM STYLE ──────────────────────────────── -->
    <Style x:Key="RiftNavItemStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#888888" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0FFFFFFF" />
                            <Setter Property="Foreground" Value="#CCCCCC" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── INTERACTIVE CARD STYLE (hover + press + scale) ──────── -->
    <Style x:Key="RiftInteractiveCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.015" ScaleY="1.015" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                         To="1.015" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                         To="1.015" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         To="0.92" Duration="0:0:0.15" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                         To="1" Duration="0:0:0.25">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                         To="1" Duration="0:0:0.25">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         To="1" Duration="0:0:0.2" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- ── HERO CARD STYLE (bigger scale + glow shift) ─────────── -->
    <Style x:Key="RiftHeroCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                         To="1.02" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                         To="1.02" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                         To="1" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                         To="1" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

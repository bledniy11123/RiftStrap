<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift">

    <!-- ══════════════════════════════════════════════════════════
         RIFT CARD
         Glass card with subtle border glow on hover
         ══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type rift:RiftCard}">
        <Setter Property="Background" Value="{DynamicResource RiftBgSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RiftBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type rift:RiftCard}">
                    <Grid>
                        <!-- Glow border (animated on hover) -->
                        <Border
                            x:Name="GlowBorder"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BorderThickness="1"
                            Opacity="{TemplateBinding GlowOpacity}">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFFFFF" />
                            </Border.BorderBrush>
                        </Border>
                        <!-- Main card -->
                        <Border
                            x:Name="CardBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         RIFT BUTTON — PRIMARY
         White fill, dark text
         ══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type rift:RiftButton}">
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type rift:RiftButton}">
                    <Border
                        x:Name="ButtonBorder"
                        Background="#FAFAFA"
                        BorderThickness="0"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            x:Name="ContentText"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="#0A0A0A" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#E0E0E0" />
                        </Trigger>
                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#C0C0C0" />
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#333333" />
                            <Setter TargetName="ContentText" Property="TextBlock.Foreground" Value="#666666" />
                        </Trigger>
                        <!-- Secondary variant -->
                        <Trigger Property="Variant" Value="Secondary">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="Transparent" />
                            <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="1" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource RiftBorderDefault}" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="ContentText" Property="TextBlock.Foreground" Value="#FAFAFA" />
                        </Trigger>
                        <!-- Ghost variant -->
                        <Trigger Property="Variant" Value="Ghost">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="Transparent" />
                            <Setter TargetName="ContentText" Property="TextBlock.Foreground" Value="#A0A0A0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         RIFT TOGGLE
         Smooth animated toggle switch
         ══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type rift:RiftToggle}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type rift:RiftToggle}">
                    <Grid>
                        <!-- Track -->
                        <Border
                            x:Name="Track"
                            Width="40"
                            Height="22"
                            CornerRadius="11"
                            Background="#1AFFFFFF"
                            BorderThickness="1"
                            BorderBrush="#15FFFFFF" />
                        <!-- Thumb -->
                        <Ellipse
                            x:Name="Thumb"
                            Width="16"
                            Height="16"
                            Fill="#A0A0A0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="3,0,0,0">
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="{Binding ThumbPosition, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="#FAFAFA" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="#FAFAFA" />
                            <Setter TargetName="Thumb" Property="Fill" Value="#0A0A0A" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="#33FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

<Window x:Class="RiftStrap.UI.Controls.Rift.RiftInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Width="420" Height="220" ShowInTaskbar="False">

    <Window.Resources>
        <DropShadowEffect x:Key="DialogShadow" BlurRadius="24" ShadowDepth="4"
                          Direction="270" Color="#000000" Opacity="0.6" />
    </Window.Resources>

    <Border Background="#0F0F0F" CornerRadius="12" BorderBrush="#1A1A1A" BorderThickness="1"
            Margin="16" Effect="{StaticResource DialogShadow}">

        <Grid Margin="28,24,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText" Grid.Row="0" Text="Title" FontSize="16" FontWeight="SemiBold"
                       Foreground="#FAFAFA" Margin="0,0,0,6" />

            <TextBlock x:Name="PromptText" Grid.Row="1" Text="Enter value:" FontSize="12"
                       Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,14" />

            <TextBox x:Name="InputBox" Grid.Row="2" FontSize="13" Padding="10,8"
                     Background="#0A0A0A" Foreground="#FAFAFA" BorderBrush="#1A1A1A"
                     BorderThickness="1" CaretBrush="#FAFAFA"
                     SelectionBrush="#33FFFFFF">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8" />
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CancelBtn" Content="Cancel" Click="Cancel_Click"
                        Background="Transparent" Foreground="#666666" BorderThickness="0"
                        Padding="16,8" FontSize="12" Cursor="Hand" />
                <Button x:Name="OkBtn" Content="OK" Click="OK_Click" IsDefault="True"
                        Background="#FAFAFA" Foreground="#0A0A0A" BorderThickness="0"
                        Padding="24,8" FontSize="12" FontWeight="SemiBold" Cursor="Hand" Margin="8,0,0,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>

<base:WpfUiDialogBase
    x:Class="RiftStrap.UI.Elements.Bootstrapper.ClassicFluentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:RiftStrap.UI.Elements.Bootstrapper.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:RiftStrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vms="clr-namespace:RiftStrap.UI.ViewModels.Bootstrapper"
    Width="460"
    Height="220"
    MinHeight="0"
    Background="#FF080808"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowBackdropType="None"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Dark background fill -->
        <Border Grid.RowSpan="3">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#080808" Offset="0" />
                    <GradientStop Color="#0C0C0C" Offset="0.5" />
                    <GradientStop Color="#0A0A0A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Hidden title bar for window chrome -->
        <ui:TitleBar Grid.Row="0" x:Name="RootTitleBar" Padding="8"
                     Title="{Binding Title, Mode=OneTime}"
                     ShowMinimize="False" ShowMaximize="False" CanMaximize="False" ShowClose="False" />

        <ui:TitleBar Grid.Row="0" VerticalAlignment="Top"
                     CanMaximize="False" ShowClose="False" ShowMaximize="False" ShowMinimize="False" />

        <!-- Main content area -->
        <Grid Grid.Row="1" Margin="24,0,24,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Rift logo -->
            <Border Grid.Column="0" Width="52" Height="52" VerticalAlignment="Top" Margin="0,4,0,0">
                <Image Width="44" Height="44"
                       Source="pack://application:,,,/Resources/RiftLogo.png"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>

            <!-- Status + Progress -->
            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock FontSize="15" FontWeight="Medium" Foreground="#C0C0C0"
                           Text="{Binding Message, Mode=OneWay}" TextWrapping="Wrap" />

                <!-- Progress bar -->
                <Grid Margin="0,14,0,0" Height="3">
                    <Border CornerRadius="1.5" Background="#0CFFFFFF" />
                    <ProgressBar Height="3" Background="Transparent" BorderThickness="0" Foreground="#888888"
                                 IsIndeterminate="{Binding ProgressIndeterminate, Mode=OneWay}"
                                 Maximum="{Binding ProgressMaximum, Mode=OneWay}"
                                 Value="{Binding ProgressValue, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Footer with cancel -->
        <Border Grid.Row="2" Padding="16,10,16,12">
            <Border.Background>
                <SolidColorBrush Color="#111111" Opacity="{Binding FooterOpacity, Mode=OneTime}" />
            </Border.Background>
            <Button Content="{x:Static resources:Strings.Common_Cancel}" Width="110"
                    HorizontalAlignment="Right" FontSize="12"
                    IsEnabled="{Binding CancelEnabled, Mode=OneWay}"
                    Command="{Binding CancelInstallCommand}" />
        </Border>
    </Grid>
</base:WpfUiDialogBase>

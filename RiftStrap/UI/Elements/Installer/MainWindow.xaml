<base:WpfUiWindow x:Class="RiftStrap.UI.Elements.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:RiftStrap.UI.Elements.Installer.Pages"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
        xmlns:resources="clr-namespace:RiftStrap.Resources"
        xmlns:dmodels="clr-namespace:RiftStrap.UI.ViewModels.Installer"
        xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
        xmlns:local="clr-namespace:RiftStrap.UI.Elements.Installer"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance dmodels:MainWindowViewModel, IsDesignTimeCreatable=True}"
        Title="RiftStrap"
        Height="640" Width="480" MinWidth="480"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <!-- Hidden navigation (code-behind dependency) -->
    <base:WpfUiWindow.Resources>
        <!-- Fade+slide entrance animation -->
        <Storyboard x:Key="ContentEntrance">
            <DoubleAnimation Storyboard.TargetName="ContentPanel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentTranslate" Storyboard.TargetProperty="Y"
                             From="20" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Logo glow pulse -->
        <Storyboard x:Key="LogoGlow" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoGlowEffect" Storyboard.TargetProperty="Opacity"
                             From="0.15" To="0.4" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Step dot scale animation -->
        <Storyboard x:Key="DotActivate">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.5" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase Oscillations="1" Springiness="5" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.5" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase Oscillations="1" Springiness="5" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </base:WpfUiWindow.Resources>

    <!-- Hidden NavigationFluent for code-behind -->
    <Grid>
        <ui:NavigationFluent x:Name="RootNavigation" Visibility="Collapsed" Frame="{Binding ElementName=RootFrame}" SelectedPageIndex="0">
            <ui:NavigationFluent.Items>
                <ui:NavigationItem Content="Welcome" PageType="{x:Type pages:WelcomePage}" Icon="ArrowCircleRight48" />
                <ui:NavigationItem Content="Install" PageType="{x:Type pages:InstallPage}" Icon="ArrowCircleRight48" />
                <ui:NavigationItem Content="Complete" PageType="{x:Type pages:CompletionPage}" Icon="ArrowCircleRight48" />
            </ui:NavigationFluent.Items>
        </ui:NavigationFluent>

        <!-- MAIN WINDOW BORDER (custom chrome) -->
        <Border CornerRadius="16" Background="#0A0A0A"
                BorderThickness="1" BorderBrush="#1AFFFFFF"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- custom title bar -->
                    <RowDefinition Height="Auto" />  <!-- logo + branding -->
                    <RowDefinition Height="Auto" />  <!-- step indicator -->
                    <RowDefinition Height="*" />     <!-- content -->
                    <RowDefinition Height="Auto" />  <!-- buttons -->
                </Grid.RowDefinitions>

                <!-- AMBIENT GLOW behind logo (decorative) -->
                <Ellipse Grid.Row="1" Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Margin="0,-40,0,0" IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#15FFFFFF" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- CUSTOM TITLE BAR -->
                <Grid Grid.Row="0" Height="40">
                    <TextBlock Text="RiftStrap" FontSize="11" Foreground="#444444" VerticalAlignment="Center" Margin="16,0,0,0" />
                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
                        <Button x:Name="MinBtn" Content="—" FontSize="10" Foreground="#666666" Width="28" Height="28"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Click="MinBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="CloseBtn" Content="✕" FontSize="10" Foreground="#666666" Width="28" Height="28"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#30FF4444" />
                                            <Setter Property="Foreground" Value="#FF6666" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- LOGO + BRANDING -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <!-- Logo with glow -->
                    <Grid HorizontalAlignment="Center">
                        <!-- Glow behind logo -->
                        <Ellipse x:Name="LogoGlowEffect" Width="120" Height="120" Opacity="0.2" IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#40FFFFFF" Offset="0" />
                                    <GradientStop Color="#00FFFFFF" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Actual logo -->
                        <Image Source="pack://application:,,,/Resources/RiftLogo.png"
                               Width="72" Height="72"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Grid>
                    <TextBlock Text="RiftStrap" FontSize="26" FontWeight="Bold" Foreground="#FAFAFA"
                               HorizontalAlignment="Center" Margin="0,12,0,0"
                               FontFamily="Inter, Segoe UI" />
                    <TextBlock Text="Your Roblox, elevated" FontSize="12" Foreground="#555555"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <!-- STEP INDICATOR -->
                <Grid Grid.Row="2" HorizontalAlignment="Center" Margin="0,24,0,16">
                    <StackPanel Orientation="Horizontal">
                        <!-- Step 1 -->
                        <Grid>
                            <Ellipse x:Name="Step1Dot" Width="10" Height="10" Fill="#FAFAFA" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1" /></Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <Border Width="48" Height="2" Margin="8,0" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop x:Name="Line1Start" Color="#FAFAFA" Offset="0" />
                                    <GradientStop x:Name="Line1End" Color="#222222" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Step 2 -->
                        <Grid>
                            <Ellipse x:Name="Step2Dot" Width="10" Height="10" Fill="#222222" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1" /></Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <Border Width="48" Height="2" Margin="8,0" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop x:Name="Line2Start" Color="#222222" Offset="0" />
                                    <GradientStop x:Name="Line2End" Color="#222222" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Step 3 -->
                        <Grid>
                            <Ellipse x:Name="Step3Dot" Width="10" Height="10" Fill="#222222" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1" /></Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- CONTENT (with entrance animation) -->
                <Border Grid.Row="3" Margin="28,0,28,0" CornerRadius="14"
                        Background="#0CFFFFFF" BorderThickness="1" BorderBrush="#0AFFFFFF"
                        Padding="20">
                    <Grid x:Name="ContentPanel" Opacity="0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="ContentTranslate" Y="20" />
                        </Grid.RenderTransform>
                        <Frame x:Name="RootFrame" NavigationUIVisibility="Hidden" />
                    </Grid>
                </Border>

                <!-- BOTTOM BUTTONS -->
                <Grid Grid.Row="4" Margin="28,16,28,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="VersionText" Grid.Column="0" FontSize="11" Foreground="#333333" VerticalAlignment="Center" />

                    <rift:RiftButton Grid.Column="2" Content="{x:Static resources:Strings.Common_Navigation_Back}"
                                     Variant="Ghost" Padding="16,10" FontSize="13"
                                     Command="{Binding BackPageCommand, Mode=OneWay}"
                                     IsEnabled="{Binding BackButtonEnabled, Mode=OneWay}"
                                     Margin="0,0,8,0" />
                    <rift:RiftButton Grid.Column="3" x:Name="NextButton"
                                     Content="{Binding NextButtonText, Mode=OneWay}"
                                     Variant="Primary" Padding="28,10" FontSize="13"
                                     Command="{Binding NextPageCommand, Mode=OneWay}"
                                     IsEnabled="{Binding NextButtonEnabled, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>

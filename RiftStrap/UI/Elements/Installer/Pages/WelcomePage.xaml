<ui:UiPage x:Class="RiftStrap.UI.Elements.Installer.Pages.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:RiftStrap.UI.Elements.Installer.Pages"
      xmlns:models="clr-namespace:RiftStrap.UI.ViewModels"
      xmlns:dmodels="clr-namespace:RiftStrap.UI.ViewModels.Installer"
      xmlns:resources="clr-namespace:RiftStrap.Resources"
      xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
      xmlns:enums="clr-namespace:RiftStrap.Enums"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance dmodels:WelcomeViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WelcomePage"
      Scrollable="True"
      Loaded="UiPage_Loaded">

    <Grid>
        <!-- Centered welcome content -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520" Margin="0,40,0,20">
            <!-- Rift logo -->
            <Image Source="pack://application:,,,/Resources/RiftLogo.png"
                   Width="72" Height="72" HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,28" />

            <!-- Welcome markdown text -->
            <controls:MarkdownTextBlock FontSize="14" MarkdownText="{Binding MainText, Mode=OneWay}" TextWrapping="Wrap"
                                        HorizontalAlignment="Center" TextAlignment="Center" />

            <!-- Version notice (inline, subtle) -->
            <Border Margin="0,20,0,0" Padding="12,8" CornerRadius="6" HorizontalAlignment="Center"
                    Background="#06FFFFFF">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding VersionNotice, Mode=OneWay}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="pack://application:,,,/Resources/MessageBox/Warning.png" />
                    <TextBlock Grid.Column="1" FontSize="12" Margin="10,0,10,0" VerticalAlignment="Center"
                               Text="{Binding VersionNotice, Mode=OneWay}" TextWrapping="Wrap"
                               Foreground="#888888" />
                    <ui:Button Grid.Column="2" Icon="ArrowDownload16" Content="Download"
                               Command="models:GlobalViewModel.OpenWebpageCommand"
                               CommandParameter="https://github.com/N3XT3R1337/RiftStrap/releases/latest" />
                </Grid>
            </Border>

            <!-- "Next to continue" hint -->
            <StackPanel HorizontalAlignment="Center" Margin="0,32,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanContinue, Mode=OneWay}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock FontSize="12" Foreground="#444444"
                           Text="{x:Static resources:Strings.Installer_Welcome_NextToContinue}"
                           TextWrapping="Wrap" HorizontalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:UiPage>

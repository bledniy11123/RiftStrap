<base:WpfUiWindow x:Class="RiftStrap.UI.Elements.Settings.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:RiftStrap.UI.Elements.Settings.Pages"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
             xmlns:resources="clr-namespace:RiftStrap.Resources"
             xmlns:dmodels="clr-namespace:RiftStrap.UI.ViewModels.Settings"
             xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance dmodels:MainWindowViewModel, IsDesignTimeCreatable=True}"
             Title="RiftStrap"
             MinWidth="1100" Width="1100" Height="680"
             Background="Transparent" WindowStyle="None" AllowsTransparency="True"
             WindowBackdropType="None" WindowStartupLocation="CenterScreen"
             Closing="WpfUiWindow_Closing" Closed="WpfUiWindow_Closed"
             Loaded="Window_Loaded">

    <base:WpfUiWindow.Resources>
        <!-- Window entrance -->
        <Storyboard x:Key="WindowEntrance">
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainScale" Storyboard.TargetProperty="ScaleX"
                             From="0.97" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainScale" Storyboard.TargetProperty="ScaleY"
                             From="0.97" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Sidebar logo glow breathing -->
        <Storyboard x:Key="LogoGlow" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="SidebarLogoGlow" Storyboard.TargetProperty="Opacity"
                             From="0.03" To="0.12" Duration="0:0:3">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </base:WpfUiWindow.Resources>

    <!-- Snackbars (absolute overlay, outside border for z-index) -->
    <Grid>
        <ui:Snackbar x:Name="AlreadyRunningSnackbar"
            Title="{x:Static resources:Strings.Menu_AlreadyRunning_Title}"
            Message="{x:Static resources:Strings.Menu_AlreadyRunning_Caption}"
            Icon="Info20" Timeout="10000" Margin="250,0,250,20" Panel.ZIndex="10" VerticalAlignment="Bottom" />
        <ui:Snackbar x:Name="SettingsSavedSnackbar"
            Title="{x:Static resources:Strings.Menu_SettingsSaved_Title}"
            Message="{x:Static resources:Strings.Menu_SettingsSaved_Message}"
            Appearance="Success" Icon="CheckmarkCircle32" Timeout="3000" Margin="250,0,250,20" Panel.ZIndex="9" VerticalAlignment="Bottom" />

        <Border x:Name="MainBorder" CornerRadius="16" ClipToBounds="True"
                BorderThickness="1" BorderBrush="#0CFFFFFF" Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="MainScale" ScaleX="0.97" ScaleY="0.97" />
            </Border.RenderTransform>

            <Grid>
                <!-- Background -->
                <Border CornerRadius="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#070709" Offset="0" />
                            <GradientStop Color="#0A0A0E" Offset="0.5" />
                            <GradientStop Color="#070707" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- ══ TITLE BAR ══ -->
                    <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <!-- Window controls (right) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,10,0">
                            <Button Content="—" FontSize="9" Foreground="#444444" Width="30" Height="26"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Click="MinBtn_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#0CFFFFFF" />
                                                <Setter Property="Foreground" Value="#888888" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="□" FontSize="9" Foreground="#444444" Width="30" Height="26"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Click="MaxBtn_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#0CFFFFFF" />
                                                <Setter Property="Foreground" Value="#888888" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="✕" FontSize="9" Foreground="#444444" Width="30" Height="26"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#20FF4444" />
                                                <Setter Property="Foreground" Value="#FF6666" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- ══ MAIN CONTENT ══ -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="230" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- ══ SIDEBAR ══ -->
                        <Grid Grid.Column="0">
                            <!-- Sidebar background -->
                            <Border CornerRadius="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#0A0A0C" Offset="0" />
                                        <GradientStop Color="#08080A" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Right edge line -->
                            <Border HorizontalAlignment="Right" Width="1" Background="#08FFFFFF" />

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Logo + branding -->
                                <Grid Grid.Row="0" Margin="20,4,20,20">
                                    <!-- Ambient glow behind logo -->
                                    <Ellipse x:Name="SidebarLogoGlow" Width="80" Height="80" Opacity="0.05"
                                             HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0" IsHitTestVisible="False">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#20FFFFFF" Offset="0" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Resources/RiftLogo.png"
                                               Width="30" Height="30" Margin="0,0,10,0"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="RiftStrap" FontSize="15" FontWeight="SemiBold" Foreground="#FAFAFA" />
                                            <TextBlock x:Name="SidebarVersion" Text="" FontSize="10" Foreground="#333333" Margin="0,-1,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Hidden NavigationFluent -->
                                <ui:NavigationFluent x:Name="RootNavigation" Visibility="Collapsed" Frame="{Binding ElementName=RootFrame}" SelectedPageIndex="0">
                                    <ui:NavigationFluent.Items>
                                        <ui:NavigationItem Content="Dashboard" PageType="{x:Type pages:DashboardPage}" Icon="Home24" Tag="dashboard" />
                                        <ui:NavigationItem Content="Themes" PageType="{x:Type pages:ThemesPage}" Icon="Color24" Tag="themes" />
                                        <ui:NavigationItem Content="Game Profiles" PageType="{x:Type pages:GameProfilesPage}" Icon="Games24" Tag="profiles" />
                                        <ui:NavigationItem Content="Optimizer" PageType="{x:Type pages:HardwareOptPage}" Icon="TopSpeed24" Tag="optimizer" />
                                        <ui:NavigationItem Content="Servers" PageType="{x:Type pages:ServerBrowserPage}" Icon="Globe24" Tag="servers" />
                                        <ui:NavigationItem Content="Hub" PageType="{x:Type pages:CommunityHubPage}" Icon="ArrowDownload16" Tag="hub" />
                                        <ui:NavigationItem Content="Creator" PageType="{x:Type pages:ThemeCreatorPage}" Icon="WrenchScrewdriver20" Tag="creator" />
                                        <ui:NavigationItem Content="Accounts" PageType="{x:Type pages:AccountsPage}" Icon="PeopleTeam20" Tag="accounts" />
                                        <ui:NavigationItem Content="Quick Launch" PageType="{x:Type pages:QuickLaunchPage}" Icon="Play24" Tag="quicklaunch" />
                                        <ui:NavigationItem Content="Analytics" PageType="{x:Type pages:AnalyticsPage}" Icon="Timer20" Tag="analytics" />
                                        <ui:NavigationItem Content="Status" PageType="{x:Type pages:StatusPage}" Icon="CheckmarkCircle32" Tag="status" />
                                        <ui:NavigationItem Content="Network" PageType="{x:Type pages:NetworkPage}" Icon="Globe24" Tag="network" />
                                        <ui:NavigationItem Content="Plugins" PageType="{x:Type pages:PluginsPage}" Icon="Apps28" Tag="plugins" />
                                        <ui:NavigationItem Content="FastFlags" PageType="{x:Type pages:FastFlagsPage}" Icon="Flag24" Tag="fastflags" />
                                        <ui:NavigationItem Content="Mods" PageType="{x:Type pages:ModsPage}" Icon="WrenchScrewdriver20" Tag="mods" />
                                        <ui:NavigationItem Content="Integrations" PageType="{x:Type pages:IntegrationsPage}" Icon="Add28" Tag="integrations" />
                                        <ui:NavigationItem Content="Behaviour" PageType="{x:Type pages:BehaviourPage}" Icon="PlaySettings20" Tag="bootstrapper" />
                                        <ui:NavigationItem Content="Appearance" PageType="{x:Type pages:AppearancePage}" Icon="PaintBrush24" Tag="appearance" />
                                        <ui:NavigationItem Content="Shortcuts" PageType="{x:Type pages:ShortcutsPage}" Icon="Apps28" Tag="shortcuts" />
                                        <ui:NavigationItem Content="TexturePacks" PageType="{x:Type pages:TexturePacksPage}" Icon="Image24" Tag="texturepacks" />
                                        <ui:NavigationItem Content="Screenshots" PageType="{x:Type pages:ScreenshotsPage}" Icon="Image24" Tag="screenshots" />
                                        <ui:NavigationItem Content="FPS" PageType="{x:Type pages:FPSPresetsPage}" Icon="TopSpeed24" Tag="fpspresets" />
                                        <ui:NavigationItem Content="FastFlagEditor" PageType="{x:Type pages:FastFlagEditorPage}" Tag="fastflageditor" Visibility="Collapsed" />
                                    </ui:NavigationFluent.Items>
                                    <ui:NavigationFluent.Footer>
                                        <ui:NavigationItem Content="Settings" PageType="{x:Type pages:RiftStrapPage}" Icon="Settings24" Tag="settings" />
                                    </ui:NavigationFluent.Footer>
                                </ui:NavigationFluent>

                                <!-- Nav items with icons -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Margin="10,0">
                                        <TextBlock Text="{x:Static resources:Strings.Menu_Nav_Main}" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" Margin="12,0,0,5" />
                                        <Button x:Name="NavDashboard" Style="{StaticResource RiftNavItemStyle}" Tag="dashboard" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◉" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Dashboard}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavThemes" Style="{StaticResource RiftNavItemStyle}" Tag="themes" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◈" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Themes}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavProfiles" Style="{StaticResource RiftNavItemStyle}" Tag="profiles" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◇" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_GameProfiles}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavOptimizer" Style="{StaticResource RiftNavItemStyle}" Tag="optimizer" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="⚡" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Optimizer}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavServers" Style="{StaticResource RiftNavItemStyle}" Tag="servers" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◎" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Servers}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavHub" Style="{StaticResource RiftNavItemStyle}" Tag="hub" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="↓" FontSize="12" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_CommunityHub}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavCreator" Style="{StaticResource RiftNavItemStyle}" Tag="creator" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="✦" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_ThemeCreator}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavAccounts" Style="{StaticResource RiftNavItemStyle}" Tag="accounts" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="○" FontSize="12" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Accounts}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavQuickLaunch" Style="{StaticResource RiftNavItemStyle}" Tag="quicklaunch" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="▶" FontSize="10" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_QuickLaunch}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavAnalytics" Style="{StaticResource RiftNavItemStyle}" Tag="analytics" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◔" FontSize="12" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Analytics}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavStatus" Style="{StaticResource RiftNavItemStyle}" Tag="status" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="●" FontSize="8" Foreground="#444444" Width="22" VerticalAlignment="Center" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Status}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavNetwork" Style="{StaticResource RiftNavItemStyle}" Tag="network" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◌" FontSize="12" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Network}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavPlugins" Style="{StaticResource RiftNavItemStyle}" Tag="plugins" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="⬡" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Plugins}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavTexturePacks" Style="{StaticResource RiftNavItemStyle}" Tag="texturepacks" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="▣" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_TexturePacks}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavScreenshots" Style="{StaticResource RiftNavItemStyle}" Tag="screenshots" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="▢" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Screenshots}" /></StackPanel>
                                        </Button>

                                        <TextBlock Text="{x:Static resources:Strings.Menu_Nav_Advanced}" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" Margin="12,14,0,5" />
                                        <Button x:Name="NavFpsPresets" Style="{StaticResource RiftNavItemStyle}" Tag="fpspresets" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◒" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_FPSPresets}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavFastFlags" Style="{StaticResource RiftNavItemStyle}" Tag="fastflags" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="⚑" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_FastFlags_Title}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavMods" Style="{StaticResource RiftNavItemStyle}" Tag="mods" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="⚙" FontSize="12" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Mods_Title}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavIntegrations" Style="{StaticResource RiftNavItemStyle}" Tag="integrations" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◫" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Integrations_Title}" /></StackPanel>
                                        </Button>

                                        <TextBlock Text="{x:Static resources:Strings.Menu_Nav_SettingsSection}" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" Margin="12,14,0,5" />
                                        <Button x:Name="NavBehaviour" Style="{StaticResource RiftNavItemStyle}" Tag="bootstrapper" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="▷" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Behaviour_Title}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavAppearance" Style="{StaticResource RiftNavItemStyle}" Tag="appearance" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="◐" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Appearance_Title}" /></StackPanel>
                                        </Button>
                                        <Button x:Name="NavShortcuts" Style="{StaticResource RiftNavItemStyle}" Tag="shortcuts" Click="NavItem_Click">
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="⌘" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Common_Shortcuts}" /></StackPanel>
                                        </Button>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Footer -->
                                <StackPanel Grid.Row="2" Margin="10,0,10,14">
                                    <Border Height="1" Background="#08FFFFFF" Margin="4,0,4,10" />
                                    <Button Style="{StaticResource RiftNavItemStyle}" Tag="settings" Click="NavItem_Click">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="⚙" FontSize="12" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_Nav_Settings}" /></StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RiftNavItemStyle}" Click="OpenAbout_Click">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="ⓘ" FontSize="11" Foreground="#444444" Width="22" /><TextBlock Text="{x:Static resources:Strings.Menu_About_Title}" /></StackPanel>
                                    </Button>
                                    <Grid Margin="4,10,4,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <rift:RiftButton Grid.Column="0" Content="{x:Static resources:Strings.Menu_Save}"
                                                         Variant="Primary" Padding="0,8" FontSize="12"
                                                         HorizontalAlignment="Stretch" Margin="0,0,6,0"
                                                         Command="{Binding SaveSettingsCommand, Mode=OneWay}" />
                                        <rift:RiftButton Grid.Column="1" Content="{x:Static resources:Strings.Common_Close}"
                                                         Variant="Ghost" Padding="12,8" FontSize="12"
                                                         Command="{Binding CloseWindowCommand, Mode=OneWay}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- ══ CONTENT AREA ══ -->
                        <Grid Grid.Column="1">
                            <!-- Content top light -->
                            <Border Height="60" VerticalAlignment="Top" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#04FFFFFF" Offset="0" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Grid x:Name="ContentWrapper" Margin="16,0,4,4">
                                <Grid.RenderTransform>
                                    <TranslateTransform x:Name="ContentTranslate" />
                                </Grid.RenderTransform>
                                <Frame x:Name="RootFrame" NavigationUIVisibility="Hidden" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>

<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.NetworkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True" Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- Diagnostics: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Title + accent line + Ping/MTU as labeled value rows ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,24">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="Network" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="Optimize DNS and network for lower ping" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Labeled value rows: diagnostic readouts -->
            <TextBlock Text="CONNECTIVITY" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,12" />

            <!-- Ping row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Roblox Connectivity" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock x:Name="PingStatus" Text="Not tested" FontSize="11" Foreground="#444444" Margin="0,2,0,0" />
                </StackPanel>
                <rift:RiftButton Grid.Column="2" Content="Test Ping" Variant="Primary" Click="TestPing_Click" VerticalAlignment="Center" Padding="14,8" FontSize="12" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,14,0,14" />

            <!-- MTU row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="MTU Discovery" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock x:Name="MtuStatus" Text="Optimal MTU not yet discovered" FontSize="11" Foreground="#444444" Margin="0,2,0,0" />
                </StackPanel>
                <rift:RiftButton Grid.Column="1" Content="Discover MTU" Variant="Secondary" Click="Mtu_Click" VerticalAlignment="Center" Padding="14,8" FontSize="12" />
            </Grid>
        </StackPanel>

        <!-- ═══ S2: DNS Benchmark header ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,10">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="DNS BENCHMARK" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" VerticalAlignment="Center" />
                <rift:RiftButton Grid.Column="1" Content="Run Benchmark" Variant="Secondary" Click="Benchmark_Click" Padding="14,8" FontSize="12" />
            </Grid>
        </StackPanel>

        <!-- ═══ S3: DNS Benchmark results as compact table ═══ -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></StackPanel.RenderTransform>

            <!-- Table header -->
            <Grid Margin="0,8,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="SERVER" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="LATENCY" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" />
                <TextBlock Grid.Column="2" Text="ADDRESS" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,4" />

            <ItemsControl x:Name="DnsResults">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2" Height="26">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Server.Name}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding DisplayText}" FontSize="13" Foreground="#666666" FontFamily="{DynamicResource RiftFontMono}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding Server.Primary}" FontSize="11" Foreground="#333333" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</ui:UiPage>

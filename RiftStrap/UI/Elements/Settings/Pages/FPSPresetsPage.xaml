<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.FPSPresetsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="700"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- S1: Title row with accent line -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,18">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1T" /></StackPanel.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="FPS" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                    <Border Width="32" Height="2" Background="#333333" VerticalAlignment="Center" Margin="14,2,14,0" CornerRadius="1" />
                    <TextBlock Text="CONTROL PANEL" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Monitor:" FontSize="11" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock x:Name="MonitorHz" Text="60 Hz" FontSize="11" FontWeight="SemiBold" Foreground="#888888" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- S2: Current FPS display + description -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,24">
            <Grid.RenderTransform><TranslateTransform x:Name="S2T" /></Grid.RenderTransform>

            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentFpsNumber" Text="60" FontSize="56" FontWeight="Bold" Foreground="#FAFAFA" VerticalAlignment="Bottom" />
                    <TextBlock Text="FPS" FontSize="14" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Bottom" Margin="8,0,0,10" />
                </StackPanel>
                <TextBlock x:Name="CurrentDescription" Text="" FontSize="12" Foreground="#444444" Margin="0,4,0,0" />
                <Border Height="1" Background="#0CFFFFFF" Margin="0,16,0,0" />
            </StackPanel>
        </Grid>

        <!-- S3: Preset buttons + custom input -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3T" /></StackPanel.RenderTransform>

            <!-- Presets label -->
            <TextBlock Text="PRESETS" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" Margin="0,0,0,10" />

            <!-- Preset buttons row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border x:Name="PresetPerformance" Padding="18,14" CornerRadius="10" Background="#06FFFFFF" Cursor="Hand"
                        MouseLeftButtonUp="Preset_Performance" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Performance" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" />
                        <TextBlock Text="30 FPS" FontSize="10" Foreground="#444444" Margin="0,3,0,0" />
                        <TextBlock Text="Battery saver" FontSize="9" Foreground="#333333" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border x:Name="PresetBalanced" Padding="18,14" CornerRadius="10" Background="#06FFFFFF" Cursor="Hand"
                        MouseLeftButtonUp="Preset_Balanced" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Balanced" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" />
                        <TextBlock Text="60 FPS" FontSize="10" Foreground="#444444" Margin="0,3,0,0" />
                        <TextBlock Text="Stable gameplay" FontSize="9" Foreground="#333333" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border x:Name="PresetQuality" Padding="18,14" CornerRadius="10" Background="#06FFFFFF" Cursor="Hand"
                        MouseLeftButtonUp="Preset_Quality" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Quality" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" />
                        <TextBlock x:Name="QualityHzLabel" Text="Hz" FontSize="10" Foreground="#444444" Margin="0,3,0,0" />
                        <TextBlock Text="Match monitor" FontSize="9" Foreground="#333333" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border x:Name="PresetUnlimited" Padding="18,14" CornerRadius="10" Background="#06FFFFFF" Cursor="Hand"
                        MouseLeftButtonUp="Preset_Unlimited">
                    <StackPanel>
                        <TextBlock Text="Unlimited" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" />
                        <TextBlock Text="9999 FPS" FontSize="10" Foreground="#444444" Margin="0,3,0,0" />
                        <TextBlock Text="Uncapped" FontSize="9" Foreground="#333333" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Custom FPS -->
            <TextBlock Text="CUSTOM" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="CustomFpsInput" Width="100" FontSize="13" Foreground="#DDDDDD" Background="#08FFFFFF"
                         BorderBrush="#0CFFFFFF" BorderThickness="1" Padding="10,8" VerticalContentAlignment="Center" />
                <rift:RiftButton Content="Apply" Variant="Secondary" Click="ApplyCustom_Click" Margin="8,0,0,0" Padding="14,8" FontSize="12" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:UiPage>

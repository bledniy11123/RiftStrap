<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.ScreenshotsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="700"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- S1: Title row with accent line + actions -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,18">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1T" /></StackPanel.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Screenshots" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                    <Border Width="32" Height="2" Background="#333333" VerticalAlignment="Center" Margin="14,2,14,0" CornerRadius="1" />
                    <TextBlock Text="GALLERY BROWSER" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <rift:RiftButton Content="Open Folder" Variant="Primary" Click="OpenFolder_Click" Margin="0,0,6,0" />
                    <rift:RiftButton Content="Clean Old" Variant="Ghost" Click="CleanOld_Click" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- S2: Stats strip -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,16">
            <Grid.RenderTransform><TranslateTransform x:Name="S2T" /></Grid.RenderTransform>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="STATS" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock x:Name="StatsCount" Text="0 screenshots" FontSize="15" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <TextBlock Text=" / " FontSize="13" Foreground="#333333" VerticalAlignment="Center" />
                <TextBlock x:Name="StatsDiskUsage" Text="0 MB" FontSize="12" Foreground="#555555" VerticalAlignment="Center" />
            </StackPanel>

            <Border Height="1" Background="#0CFFFFFF" VerticalAlignment="Bottom" Margin="0,10,0,0" />
        </Grid>

        <!-- S3: Screenshots list + empty state -->
        <Grid x:Name="S3" Grid.Row="2" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="S3T" /></Grid.RenderTransform>

            <ItemsControl x:Name="ScreenshotsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,4" Padding="14,8" CornerRadius="8" Background="#06FFFFFF"
                                Cursor="Hand" MouseLeftButtonUp="ScreenshotItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding FileName}" FontSize="13" FontWeight="Medium" Foreground="#DDDDDD" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding DateText}" FontSize="11" Foreground="#444444" VerticalAlignment="Center" Margin="16,0,0,0" />
                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="11" Foreground="#333333" VerticalAlignment="Center" Margin="16,0,0,0" Width="60" TextAlignment="Right" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="No screenshots found" FontSize="15" FontWeight="Medium" Foreground="#555555" HorizontalAlignment="Center" />
                <TextBlock Text="Take screenshots in Roblox and they will appear here" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:UiPage>

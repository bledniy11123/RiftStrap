<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.IntegrationsPage"
      x:Name="IntegrationsPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:models="clr-namespace:RiftStrap.UI.ViewModels"
      xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
      xmlns:resources="clr-namespace:RiftStrap.Resources"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DesignHeight="1080" d:DesignWidth="800"
      Title="IntegrationsPage"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- Connections: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Title + Activity Tracking group ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="Integrations" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="Discord, activity tracking, and more" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Section: ACTIVITY TRACKING -->
            <TextBlock Text="ACTIVITY TRACKING" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,12" />

            <!-- Row: Enable Activity Tracking -->
            <Grid x:Name="ActivityTrackingOption">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_EnableActivityTracking_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_EnableActivityTracking_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" x:Name="ActivityTrackingToggle" IsChecked="{Binding ActivityTrackingEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

            <!-- Row: Query Server Location -->
            <Grid IsEnabled="{Binding IsChecked, ElementName=ActivityTrackingToggle, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_QueryServerLocation_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{Binding Source={x:Static resources:Strings.Menu_Integrations_QueryServerLocation_Description}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://ipinfo.io'}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowServerDetailsEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

            <!-- Row: Desktop App -->
            <Grid IsEnabled="{Binding IsChecked, ElementName=ActivityTrackingToggle, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_DesktopApp_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{Binding Source={x:Static resources:Strings.Menu_Integrations_DesktopApp_Description}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://riftstrap.com/wiki/features/dont-exit-to-desktop-app/'}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding DisableAppPatchEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>

        <!-- ═══ S2: Discord Rich Presence group ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="DISCORD RICH PRESENCE" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,4" />
            <controls:MarkdownTextBlock MarkdownText="{Binding Source={x:Static resources:Strings.Menu_Integrations_RequiresActivityTracking}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://riftstrap.com/wiki/features/discord-rich-presence/'}" TextWrapping="Wrap" Foreground="#444444" FontSize="11" Margin="0,0,0,12" />

            <!-- Row: Show Game Activity -->
            <Grid x:Name="DiscordActivityOption" IsEnabled="{Binding IsChecked, ElementName=ActivityTrackingToggle, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_ShowGameActivity_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{Binding Source={x:Static resources:Strings.Menu_Integrations_ShowGameActivity_Description}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://riftstrap.com/wiki/help/discord-rich-presence-not-working/'}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" x:Name="DiscordActivityToggle" IsChecked="{Binding DiscordActivityEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

            <!-- Row: Allow Activity Joining -->
            <Grid IsEnabled="{Binding IsChecked, ElementName=DiscordActivityToggle, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_AllowActivityJoining_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_AllowActivityJoining_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding DiscordActivityJoinEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

            <!-- Row: Show Account on Profile -->
            <Grid IsEnabled="{Binding IsChecked, ElementName=DiscordActivityToggle, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_ShowAccountOnProfile_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_ShowAccountOnProfile_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding DiscordAccountOnProfile, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>

        <!-- ═══ S3: Custom Integrations — expandable section ═══ -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="CUSTOM INTEGRATIONS" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="{x:Static resources:Strings.Menu_Integrations_Custom_Description}" TextWrapping="Wrap" Foreground="#444444" FontSize="11" Margin="0,0,0,12" />

            <Border BorderBrush="#08FFFFFF" BorderThickness="1" CornerRadius="8" Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="CustomIntegrationsListBox" Grid.Row="0" Grid.Column="0" Margin="0,0,4,0" ItemsSource="{Binding CustomIntegrations, Mode=OneWay}" DisplayMemberPath="Name" SelectionChanged="CustomIntegrationSelection" SelectedIndex="{Binding SelectedCustomIntegrationIndex, Mode=TwoWay}" />
                    <Grid Grid.Row="1" Grid.Column="0" Margin="0,8,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Margin="0,0,4,0" Icon="Add28" Content="{x:Static resources:Strings.Common_New}" HorizontalAlignment="Stretch" Command="{Binding AddIntegrationCommand, Mode=OneTime}" />
                        <ui:Button Grid.Column="1" Margin="4,0,0,0" Icon="Delete28" Content="{x:Static resources:Strings.Common_Delete}" HorizontalAlignment="Stretch" Appearance="Danger" IsEnabled="{Binding IsCustomIntegrationSelected, Mode=OneWay}" Command="{Binding DeleteIntegrationCommand, Mode=OneTime}" />
                    </Grid>
                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="4,0,0,0">
                        <StackPanel.Style>
                            <Style>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCustomIntegrationSelected}" Value="False">
                                        <Setter Property="StackPanel.Visibility" Value="Hidden"></Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static resources:Strings.Common_Name}" Foreground="#444444" FontSize="11" />
                        <ui:TextBox Margin="0,4,0,0" Text="{Binding SelectedCustomIntegration.Name, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,8,0,0" Text="{x:Static resources:Strings.Menu_Integrations_Custom_AppLocation}" Foreground="#444444" FontSize="11" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" PlaceholderText="C:\Windows\System32\cmd.exe" Text="{Binding SelectedCustomIntegration.Location}" />
                            <ui:Button Grid.Column="1" Margin="8,0,0,0" Height="34" Icon="Folder24" Content="{x:Static resources:Strings.Common_Browse}" Command="{Binding BrowseIntegrationLocationCommand}" />
                        </Grid>
                        <TextBlock Margin="0,8,0,0" Text="{x:Static resources:Strings.Menu_Integrations_Custom_LaunchArgs}" Foreground="#444444" FontSize="11" />
                        <ui:TextBox Margin="0,4,0,0" PlaceholderText="{Binding Source='/k echo {0}', Converter={StaticResource StringFormatConverter}, ConverterParameter={x:Static resources:Strings.Menu_Integrations_Custom_LaunchArgs_Placeholder}}" Text="{Binding SelectedCustomIntegration.LaunchArgs}" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True" />
                        <CheckBox Margin="0,8,0,0" Content="{x:Static resources:Strings.Menu_Integrations_Custom_AutoClose}" IsChecked="{Binding SelectedCustomIntegration.AutoClose}" />
                    </StackPanel>
                    <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="{x:Static resources:Strings.Menu_Integrations_Custom_NoneSelected}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#444444">
                        <TextBlock.Style>
                            <Style>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCustomIntegrationSelected}" Value="True">
                                        <Setter Property="TextBlock.Visibility" Value="Hidden"></Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</ui:UiPage>

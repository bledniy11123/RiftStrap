<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.ShortcutsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:RiftStrap.UI.Elements.Settings.Pages"
      xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
      xmlns:dmodels="clr-namespace:RiftStrap.UI.ViewModels.Settings"
      xmlns:resources="clr-namespace:RiftStrap.Resources"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance dmodels:ShortcutsViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="ShortcutsPage"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- Checklist: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Title + accent line + Extract Icons toggle ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="Shortcuts" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="Desktop and Start menu shortcuts" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Extract Icons — clean checkbox row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Shortcuts_ExtractIcons_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{Binding Source={x:Static resources:Strings.Menu_Shortcuts_ExtractIcons_Description}, Converter={StaticResource StringFormatConverter},ConverterParameter='https://riftstrap.com/wiki/info/using-roblox-icons-for-shortcuts/'}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ExtractIconsTask.NewState, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>

        <!-- ═══ S2: General Shortcuts — checklist rows ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="GENERAL SHORTCUTS" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="{x:Static resources:Strings.Menu_Shortcuts_General_Description}" Foreground="#444444" FontSize="11" Margin="0,0,0,12" />

            <!-- Desktop shortcut -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.Common_Shortcuts_Desktop}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding DesktopIconTask.NewState, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,8,0,8" />

            <!-- Start Menu shortcut -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.Common_Shortcuts_StartMenu}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding StartMenuIconTask.NewState, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>

        <!-- ═══ S3: Function Shortcuts ═══ -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="FUNCTION SHORTCUTS" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="{x:Static resources:Strings.Menu_Shortcuts_Function_Description}" Foreground="#444444" FontSize="11" Margin="0,0,0,12" />

            <!-- Launch Roblox -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.LaunchMenu_LaunchRoblox}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding PlayerIconTask.NewState, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,8,0,8" />

            <!-- Launch Studio (conditional visibility) -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStudioOptionVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.LaunchMenu_LaunchRobloxStudio}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding StudioIconTask.NewState, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Height" Value="1" />
                        <Setter Property="Background" Value="#08FFFFFF" />
                        <Setter Property="Margin" Value="0,8,0,8" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStudioOptionVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Settings shortcut -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.Menu_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding SettingsIconTask.NewState, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>
    </Grid>
</ui:UiPage>

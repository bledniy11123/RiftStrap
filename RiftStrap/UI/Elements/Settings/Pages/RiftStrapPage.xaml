<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.RiftStrapPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:RiftStrap.UI.Elements.Settings.Pages"
      xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
      xmlns:models="clr-namespace:RiftStrap.UI.ViewModels.Settings"
      xmlns:resources="clr-namespace:RiftStrap.Resources"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      d:DataContext="{d:DesignInstance Type=models:RiftStrapViewModel}"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="BehaviourPage"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- About + Config: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Rift logo watermark -->
        <Image Source="pack://application:,,,/Resources/RiftLogo.png"
               Width="80" Height="80" Opacity="0.06" HorizontalAlignment="Right" VerticalAlignment="Top"
               Margin="0,0,0,0" RenderOptions.BitmapScalingMode="HighQuality" IsHitTestVisible="False"
               Grid.RowSpan="3" />

        <!-- ═══ S1: Title + accent line ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="RiftStrap configuration and data export" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </StackPanel>

        <!-- ═══ S2: Config toggles as inline rows ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="CONFIGURATION" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,14" />

            <!-- Auto Update -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Behaviour_AutoUpdate_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Behaviour_AutoUpdate_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding UpdateCheckingEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,12,0,12" />

            <!-- Analytics -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_RiftStrap_Analytics_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{Binding Source={x:Static resources:Strings.Menu_RiftStrap_Analytics_Description}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://riftstrap.com/wiki/info/privacy-policy/'}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AnalyticsEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,12,0,12" />

            <!-- Web Environment (dev mode only) -->
            <Grid Visibility="{Binding Path=WebEnvironmentVisibility, Mode=OneTime}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Web environment" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="Site to use for metrics" FontSize="11" Foreground="#444444" />
                </StackPanel>
                <ComboBox Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding WebEnvironments, Mode=OneWay}" SelectedValue="{Binding WebEnvironment, Mode=TwoWay}" />
            </Grid>
        </StackPanel>

        <!-- ═══ S3: Export section at bottom — compact layout ═══ -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="EXPORT DATA" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="{x:Static resources:Strings.Menu_RiftStrap_ExportData_Description}" FontSize="11" Foreground="#444444" Margin="0,0,0,12" TextWrapping="Wrap" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" Name="ShouldExportConfig" Content="{x:Static resources:Strings.Menu_RiftStrap_ExportData_ExportConfig}" IsChecked="{Binding ShouldExportConfig}" Margin="0,0,16,0" />
                <CheckBox Grid.Column="1" Name="ShouldExportLogs" Content="{x:Static resources:Strings.Menu_RiftStrap_ExportData_ExportLogs}" IsChecked="{Binding ShouldExportLogs}" />
                <rift:RiftButton Grid.Column="3" Content="{x:Static resources:Strings.Common_Export}" Variant="Primary" Padding="16,8" FontSize="12" Command="{Binding ExportDataCommand}">
                    <rift:RiftButton.Style>
                        <Style TargetType="rift:RiftButton">
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ElementName=ShouldExportConfig, Path=IsChecked}" Value="False" />
                                        <Condition Binding="{Binding ElementName=ShouldExportLogs, Path=IsChecked}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsEnabled" Value="False" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                            <Setter Property="IsEnabled" Value="True" />
                        </Style>
                    </rift:RiftButton.Style>
                </rift:RiftButton>
            </Grid>
        </StackPanel>
    </Grid>
</ui:UiPage>

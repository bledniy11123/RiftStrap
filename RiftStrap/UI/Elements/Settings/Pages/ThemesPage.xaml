<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.ThemesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="700"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S4" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.24" />
            <DoubleAnimation Storyboard.TargetName="S4T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.24">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- S1: Title row with accent line + filter pills + action buttons inline -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,18">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1T" /></StackPanel.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Themes" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                    <!-- Accent line -->
                    <Border Width="32" Height="2" Background="#333333" VerticalAlignment="Center" Margin="14,2,14,0" CornerRadius="1" />
                    <!-- Filter pills inline on same row -->
                    <rift:RiftButton x:Name="FilterAll" Content="All" Variant="Secondary" Click="Filter_Click" Tag="All" Padding="10,5" FontSize="11" Margin="0,0,4,0" />
                    <rift:RiftButton x:Name="FilterCursors" Content="Cursors" Variant="Ghost" Click="Filter_Click" Tag="Cursors" Padding="10,5" FontSize="11" Margin="0,0,4,0" />
                    <rift:RiftButton x:Name="FilterFonts" Content="Fonts" Variant="Ghost" Click="Filter_Click" Tag="Fonts" Padding="10,5" FontSize="11" Margin="0,0,4,0" />
                    <rift:RiftButton x:Name="FilterSounds" Content="Sounds" Variant="Ghost" Click="Filter_Click" Tag="Sounds" Padding="10,5" FontSize="11" Margin="0,0,4,0" />
                    <rift:RiftButton x:Name="FilterTextures" Content="Textures" Variant="Ghost" Click="Filter_Click" Tag="Textures" Padding="10,5" FontSize="11" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <rift:RiftButton Content="Install .rifttheme" Variant="Primary" Click="InstallTheme_Click" Margin="0,0,6,0" />
                    <rift:RiftButton Content="Scan Content" Variant="Ghost" Click="ScanContent_Click" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- S2: Active theme — horizontal strip (not card), just data + action -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,16">
            <Grid.RenderTransform><TranslateTransform x:Name="S2T" /></Grid.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="ACTIVE" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ActiveThemeName" Text="None" FontSize="15" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                    <TextBlock Text=" / " FontSize="13" Foreground="#333333" VerticalAlignment="Center" />
                    <TextBlock x:Name="ActiveThemeAuthor" Text="No theme applied" FontSize="12" Foreground="#555555" VerticalAlignment="Center" />
                </StackPanel>

                <rift:RiftButton x:Name="RemoveThemeButton" Grid.Column="2" Content="Remove" Variant="Ghost" Click="RemoveTheme_Click" VerticalAlignment="Center" Visibility="Collapsed" Padding="8,4" FontSize="11" />
            </Grid>

            <!-- Thin divider -->
            <Border Height="1" Background="#0CFFFFFF" VerticalAlignment="Bottom" Margin="0,10,0,0" />
        </Grid>

        <!-- S3: Themes grid — compact items, no heavy borders -->
        <Grid x:Name="S3" Grid.Row="2" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="S3T" /></Grid.RenderTransform>
        <ItemsControl x:Name="ThemesList">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="186" Margin="0,0,10,10" Padding="12,10" CornerRadius="10" Cursor="Hand"
                            Background="#06FFFFFF" MouseLeftButtonUp="ThemeCard_Click">
                        <StackPanel>
                            <!-- Preview area — subtle, no border -->
                            <Border Height="88" CornerRadius="8" Margin="0,0,0,10" Background="#04FFFFFF">
                                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#333333" />
                            </Border>

                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="10" Foreground="#444444" Margin="0,3,0,0">
                                <Run Text="by" />
                                <Run Text="{Binding Author}" />
                            </TextBlock>
                            <TextBlock Text="{Binding Category}" FontSize="9" Foreground="#333333" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </Grid>

        <!-- S4: Empty state — centered, minimal -->
        <StackPanel x:Name="S4" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"
                    Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S4T" /></StackPanel.RenderTransform>
            <TextBlock Text="No themes installed" FontSize="15" FontWeight="Medium" Foreground="#555555" HorizontalAlignment="Center" />
            <TextBlock Text="Install a .rifttheme file or browse the community hub" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,6,0,0" />
        </StackPanel>
    </Grid>
</ui:UiPage>

<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.ServerBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S4" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.24" />
            <DoubleAnimation Storyboard.TargetName="S4T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.24">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- S1: Title with accent line — "Search Console" feel -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,16">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1T" /></StackPanel.RenderTransform>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Server Browser" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <Border Width="32" Height="2" Background="#333333" VerticalAlignment="Center" Margin="14,2,0,0" CornerRadius="1" />
            </StackPanel>
        </StackPanel>

        <!-- S2: Search input inline — just TextBox with subtle bottom border, no card -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,18">
            <Grid.RenderTransform><TranslateTransform x:Name="S2T" /></Grid.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox x:Name="PlaceIdInput" PlaceholderText="Enter Place ID..." Margin="0,0,10,0" />
                <rift:RiftButton x:Name="SearchButton" Grid.Column="1" Content="Search" Variant="Primary" Click="Search_Click" />
            </Grid>

            <!-- Subtle bottom line -->
            <Border Height="1" Background="#08FFFFFF" VerticalAlignment="Bottom" Margin="0,8,0,0" />
        </Grid>

        <!-- S3: Game info inline when found — not in a card, just text -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3T" /></StackPanel.RenderTransform>

            <StackPanel x:Name="GameInfoCard" Visibility="Collapsed" Margin="0,0,0,16">
                <TextBlock x:Name="GameNameText" Text="" FontSize="18" FontWeight="SemiBold" Foreground="#FAFAFA" />
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock x:Name="GamePlayingText" FontSize="12" Foreground="#666666" />
                    <TextBlock Text=" / " FontSize="12" Foreground="#222222" Margin="6,0" />
                    <TextBlock x:Name="GameVisitsText" FontSize="12" Foreground="#444444" />
                </StackPanel>
                <Border Height="1" Background="#08FFFFFF" Margin="0,12,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- S4: Server list as compact rows with dividers + right-aligned join -->
        <Grid x:Name="S4" Grid.Row="3" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="S4T" /></Grid.RenderTransform>

            <ItemsControl x:Name="ServerList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Grid Margin="0,8,0,8" Cursor="Hand" MouseLeftButtonUp="ServerCard_Click">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Server ID + players -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="13" FontWeight="Medium" Foreground="#DDDDDD" FontFamily="{DynamicResource RiftFontMono}">
                                        <Run Text="Server " />
                                        <Run Text="{Binding Id}" />
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="#444444" Margin="0,3,0,0">
                                        <Run Text="{Binding FillText, Mode=OneWay}" />
                                        <Run Text=" players" />
                                    </TextBlock>
                                </StackPanel>

                                <!-- Fill bar — compact -->
                                <Grid Grid.Column="1" Width="60" Height="4" Margin="16,0" VerticalAlignment="Center">
                                    <Border CornerRadius="2" Background="#08FFFFFF" />
                                    <Border CornerRadius="2" Background="{DynamicResource RiftAccentBrush}" HorizontalAlignment="Left"
                                            Width="60" RenderTransformOrigin="0,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="{Binding FillFraction, Mode=OneWay}" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>

                                <!-- Join button right-aligned, compact -->
                                <rift:RiftButton Grid.Column="2" Content="Join" Variant="Ghost" Padding="10,5" FontSize="11" Click="JoinServer_Click" Tag="{Binding Id}" />
                            </Grid>

                            <!-- Thin divider -->
                            <Border Height="1" Background="#06FFFFFF" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Loading -->
            <TextBlock x:Name="LoadingText" Text="" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#444444" />

            <!-- Pagination -->
            <StackPanel x:Name="PaginationPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" Visibility="Collapsed">
                <rift:RiftButton x:Name="PrevButton" Content="Previous" Variant="Ghost" Click="PrevPage_Click" Margin="0,0,8,0" FontSize="11" />
                <rift:RiftButton x:Name="NextButton" Content="Next" Variant="Ghost" Click="NextPage_Click" FontSize="11" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:UiPage>

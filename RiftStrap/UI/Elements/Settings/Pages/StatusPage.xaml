<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.StatusPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True" Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- Health Check: 2-section entrance + pulsing dot -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <!-- Pulsing dot animation -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="StatusDot" Storyboard.TargetProperty="Opacity"
                             From="1" To="0.3" Duration="0:0:1" AutoReverse="True">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Overall status — big text + pulsing dot ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,24">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <!-- Title row with Refresh -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Roblox Status" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
                    <TextBlock Text="Real-time service health monitoring" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
                    <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FAFAFA" Offset="0" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>
                <rift:RiftButton Grid.Column="1" Content="Refresh" Variant="Secondary" Click="Refresh_Click" VerticalAlignment="Top" Padding="14,8" FontSize="12" />
            </Grid>

            <!-- Big status display -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusDot" Width="14" Height="14" Fill="#444444" VerticalAlignment="Center" Margin="0,0,14,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="OverallText" Text="Checking..." FontSize="28" FontWeight="Bold" Foreground="#FAFAFA" />
                    <TextBlock x:Name="OverallDetail" Text="" FontSize="12" Foreground="#444444" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- ═══ S2: Services as compact rows with status dots — NO cards ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="SERVICES" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,10" />

            <ItemsControl x:Name="ServiceList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,0" Height="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>

                            <!-- Status dot -->
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#333333" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHealthy}" Value="True">
                                                <Setter Property="Fill" Value="#FAFAFA" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock Grid.Column="1" Text="{Binding Endpoint.Name}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="11" Foreground="#444444" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="3" Text="{Binding LatencyText}" FontSize="12" Foreground="#333333" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{DynamicResource RiftFontMono}" />

                            <!-- Bottom divider via border trick -->
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</ui:UiPage>

<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="850"
      Scrollable="True"
      Loaded="Page_Loaded_Anim">

    <ui:UiPage.Resources>
        <!-- Staggered entrance for sections -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="Section1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="Section1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="Section2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="Section2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="Section3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="Section3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="Section4" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.24" />
            <DoubleAnimation Storyboard.TargetName="Section4Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.24">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ ROW 1: GREETING — no box, just typography ═══ -->
        <Grid x:Name="Section1" Grid.Row="0" Margin="4,0,0,24" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="Section1Slide" Y="18" /></Grid.RenderTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="GreetingText" FontSize="28" FontWeight="Bold" Foreground="#FAFAFA" />
                <TextBlock Text="Your Roblox experience, elevated." FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
                <!-- Accent line -->
                <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FAFAFA" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </StackPanel>

            <!-- Rift watermark -->
            <Image Grid.Column="1" Source="pack://application:,,,/Resources/RiftLogo.png"
                   Width="36" Height="36" Opacity="0.06" VerticalAlignment="Top" Margin="0,4,0,0"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Grid>

        <!-- ═══ ROW 2: TWO COLUMN LAYOUT ═══ -->
        <Grid x:Name="Section2" Grid.Row="1" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="Section2Slide" Y="18" /></Grid.RenderTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT COLUMN ═══ -->
            <StackPanel Grid.Column="0">

                <!-- LAUNCH CARD — the hero, tallest element -->
                <Border Style="{StaticResource RiftHeroCard}" Margin="0,0,0,10" Padding="0" ClipToBounds="True"
                        MouseLeftButtonUp="LaunchRoblox_Click">
                    <Grid Height="130">
                        <!-- Background with unique radial glow from left -->
                        <Border CornerRadius="14">
                            <Border.Background>
                                <RadialGradientBrush Center="0,0.5" GradientOrigin="-0.1,0.5" RadiusX="0.9" RadiusY="1.2">
                                    <GradientStop Color="#14FFFFFF" Offset="0" />
                                    <GradientStop Color="#06FFFFFF" Offset="0.6" />
                                    <GradientStop Color="#03FFFFFF" Offset="1" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>

                        <Grid Margin="24,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="▶  Launch Roblox" FontSize="17" FontWeight="SemiBold" Foreground="#FAFAFA" />
                                <TextBlock Text="Start playing with optimized settings" FontSize="11" Foreground="#555555" Margin="0,5,0,0" />
                                <TextBlock Text="FPS uncapped · Hardware optimized" FontSize="9" Foreground="#2A2A2A" Margin="0,4,0,0" />
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="→" FontSize="22" Foreground="#222222" VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- QUICK ACTIONS ROW -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource RiftInteractiveCard}" Padding="12,14"
                            MouseLeftButtonUp="OpenFastFlags_Click" Background="#08FFFFFF">
                        <StackPanel>
                            <TextBlock Text="⚑" FontSize="16" Foreground="#333333" Margin="0,0,0,8" />
                            <TextBlock Text="FastFlags" FontSize="12" FontWeight="Medium" Foreground="#B0B0B0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource RiftInteractiveCard}" Padding="12,14"
                            MouseLeftButtonUp="OpenThemes_Click" Background="#08FFFFFF">
                        <StackPanel>
                            <TextBlock Text="◈" FontSize="16" Foreground="#333333" Margin="0,0,0,8" />
                            <TextBlock Text="Themes" FontSize="12" FontWeight="Medium" Foreground="#B0B0B0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource RiftInteractiveCard}" Padding="12,14"
                            MouseLeftButtonUp="LaunchOverlay_Click" Background="#08FFFFFF">
                        <StackPanel>
                            <TextBlock Text="◔" FontSize="16" Foreground="#333333" Margin="0,0,0,8" />
                            <TextBlock Text="Overlay" FontSize="12" FontWeight="Medium" Foreground="#B0B0B0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ACTIVITY (x:Name="Section3" for stagger) -->
                <Grid x:Name="Section3" Opacity="0">
                    <Grid.RenderTransform><TranslateTransform x:Name="Section3Slide" Y="18" /></Grid.RenderTransform>

                    <Border CornerRadius="14" Padding="18,16" MinHeight="120">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#06FFFFFF" Offset="0" />
                                <GradientStop Color="#03FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="RECENT ACTIVITY" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" Margin="0,0,0,12" />
                            <TextBlock x:Name="ActivityPlaceholder"
                                       Text="No activity yet. Launch a game to start tracking."
                                       FontSize="12" Foreground="#222222" TextWrapping="Wrap" />
                            <ItemsControl x:Name="ActivityList" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- ═══ RIGHT COLUMN — stats, compact ═══ -->
            <StackPanel Grid.Column="2" x:Name="Section4" Opacity="0">
                <StackPanel.RenderTransform><TranslateTransform x:Name="Section4Slide" Y="18" /></StackPanel.RenderTransform>

                <TextBlock Text="STATUS" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" Margin="0,0,0,10" />

                <!-- Stat rows — no boxes, just clean lines -->
                <Grid Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Roblox -->
                    <Border Grid.Row="0" Padding="0,10" BorderThickness="0,0,0,1" BorderBrush="#08FFFFFF">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Roblox" FontSize="12" Foreground="#666666" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock x:Name="RobloxVersionText" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" HorizontalAlignment="Right" />
                                <TextBlock x:Name="RobloxChannelText" Text="Production" FontSize="9" Foreground="#333333" HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- RiftStrap -->
                    <Border Grid.Row="1" Padding="0,10" BorderThickness="0,0,0,1" BorderBrush="#08FFFFFF">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="RiftStrap" FontSize="12" Foreground="#666666" VerticalAlignment="Center" />
                            <TextBlock x:Name="RiftStrapVersionText" Grid.Column="1" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                        </Grid>
                    </Border>

                    <!-- FastFlags -->
                    <Border Grid.Row="2" Padding="0,10" BorderThickness="0,0,0,1" BorderBrush="#08FFFFFF">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FastFlags" FontSize="12" Foreground="#666666" VerticalAlignment="Center" />
                            <TextBlock x:Name="FastFlagCountText" Grid.Column="1" Text="0" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                        </Grid>
                    </Border>

                    <!-- Mods -->
                    <Border Grid.Row="3" Padding="0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mods" FontSize="12" Foreground="#666666" VerticalAlignment="Center" />
                            <TextBlock x:Name="ModCountText" Grid.Column="1" Text="0" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Hardware tier badge -->
                <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#08FFFFFF" Offset="0" />
                            <GradientStop Color="#04FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="HARDWARE TIER" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" Margin="0,0,0,6" />
                        <TextBlock x:Name="HardwareTierText" Text="Detecting..." FontSize="15" FontWeight="Bold" Foreground="#888888" />
                        <TextBlock x:Name="HardwareTierDesc" Text="" FontSize="10" Foreground="#333333" Margin="0,3,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Uptime / session info -->
                <Border CornerRadius="10" Padding="14,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#06FFFFFF" Offset="0" />
                            <GradientStop Color="#03FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="SESSION" FontSize="9" FontWeight="SemiBold" Foreground="#2A2A2A" Margin="0,0,0,6" />
                        <TextBlock x:Name="SessionText" Text="No active session" FontSize="11" Foreground="#444444" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</ui:UiPage>

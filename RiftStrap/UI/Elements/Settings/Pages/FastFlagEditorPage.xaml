<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.FastFlagEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:RiftStrap.UI.Elements.Settings.Pages"
      xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
      xmlns:resources="clr-namespace:RiftStrap.Resources"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FastFlagEditorPage"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- IDE: no stagger, instant toolbar feel -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.06" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="12" To="0" Duration="0:0:0.4" BeginTime="0:0:0.06">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <!-- IDE layout: NO title header — toolbar + search + datagrid -->
    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Toolbar — banner/search takes full width ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0">
            <!-- Info banner -->
            <TextBlock Margin="0,0,0,2" Text="{x:Static resources:Strings.Menu_FastFlagEditor_Description}" FontSize="12" Foreground="#444444" />
            <controls:MarkdownTextBlock FontSize="11" FontWeight="Bold" Margin="0,0,0,8" MarkdownText="{Binding Source={x:Static resources:Strings.Menu_FastFlagEditor_AllowlistInformation}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://devforum.roblox.com/t/allowlist-for-local-client-configuration-via-fast-flags/3966569'}" Foreground="#444444" />

            <ui:InfoBar Margin="0,0,0,10" Padding="8" Title="{x:Static resources:Strings.Menu_FastFlagEditor_BannerTitle}" IsOpen="True" Message="{x:Static resources:Strings.Menu_FastFlagEditor_BannerText}" Severity="Warning" IsClosable="False" />

            <!-- Toolbar pills — horizontal strip -->
            <Border BorderBrush="#08FFFFFF" BorderThickness="1" CornerRadius="8" Padding="6,4" Margin="0,0,0,10">
                <WrapPanel Orientation="Horizontal">
                    <rift:RiftButton Content="{x:Static resources:Strings.Menu_FastFlagEditor_Back}" Variant="Ghost" Padding="10,5" FontSize="11" Click="BackButton_Click" Margin="0,0,4,0" />
                    <Border Width="1" Background="#08FFFFFF" Margin="2,2,6,2" />
                    <rift:RiftButton Content="{x:Static resources:Strings.Menu_FastFlagEditor_AddNew}" Variant="Secondary" Padding="10,5" FontSize="11" Click="AddButton_Click" Margin="0,0,4,0" />
                    <rift:RiftButton Content="{x:Static resources:Strings.Menu_FastFlagEditor_DeleteSelected}" Variant="Ghost" Padding="10,5" FontSize="11" Click="DeleteButton_Click" Margin="0,0,4,0">
                        <rift:RiftButton.Style>
                            <Style TargetType="rift:RiftButton">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=DataGrid, Path=SelectedItems.Count}" Value="0">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </rift:RiftButton.Style>
                    </rift:RiftButton>
                    <ToggleButton x:Name="TogglePresetsButton" Content="{x:Static resources:Strings.Menu_FastFlagEditor_ShowPresetFlags}" Click="ToggleButton_Click" Margin="0,0,4,0" FontSize="11" Padding="10,5" />
                    <rift:RiftButton Content="{x:Static resources:Strings.Menu_FastFlagEditor_ExportJson}" Variant="Ghost" Padding="10,5" FontSize="11" Click="ExportJSONButton_Click" />
                </WrapPanel>
            </Border>

            <!-- Search bar — full width -->
            <ui:TextBox x:Name="SearchTextBox" Icon="Search32" PlaceholderText="{x:Static resources:Strings.Menu_FastFlagEditor_Search}" TextChanged="SearchTextBox_TextChanged" Margin="0,0,0,8" />
        </StackPanel>

        <!-- ═══ S2: DataGrid — monospace, dark row alternation ═══ -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="S2Slide" Y="12" /></Grid.RenderTransform>

            <DataGrid Name="DataGrid" HeadersVisibility="Column" GridLinesVisibility="None" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" CellEditEnding="DataGrid_CellEditEnding"
                      CanUserReorderColumns="False" AlternatingRowBackground="#06FFFFFF" RowBackground="Transparent"
                      Background="Transparent" BorderThickness="0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#08FFFFFF" />
                        <Setter Property="Height" Value="28" />
                        <Setter Property="Padding" Value="8,0,8,0" />
                        <Setter Property="BorderBrush" Value="#08FFFFFF" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="Foreground" Value="#666666" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontWeight" Value="Bold" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource TextOnAccentFillColorPrimary}" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource SystemAccentColorSecondary}" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                        <Setter Property="Height" Value="30" />
                        <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="6,0,6,0">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static resources:Strings.Common_Name}" Binding="{Binding Name}" />
                    <DataGridTextColumn Header="{x:Static resources:Strings.Common_Value}" Binding="{Binding Value}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</ui:UiPage>

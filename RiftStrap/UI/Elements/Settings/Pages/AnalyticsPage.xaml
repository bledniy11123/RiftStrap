<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.AnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True" Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- Stats Dashboard: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: 4 big numbers across top — NO boxes, just number + label ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,28">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <!-- Title -->
            <TextBlock Text="Analytics" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="Your play time stats -- stored locally" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- 4 stat columns — bare numbers, no boxes -->
            <UniformGrid Rows="1">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock x:Name="TodayText" Text="0h" FontSize="32" FontWeight="Bold" Foreground="#FAFAFA" FontFamily="{DynamicResource RiftFontMono}" />
                    <TextBlock Text="TODAY" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Margin="0,0,12,0">
                    <TextBlock x:Name="WeekText" Text="0h" FontSize="32" FontWeight="Bold" Foreground="#FAFAFA" FontFamily="{DynamicResource RiftFontMono}" />
                    <TextBlock Text="THIS WEEK" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Margin="0,0,12,0">
                    <TextBlock x:Name="TotalText" Text="0h" FontSize="32" FontWeight="Bold" Foreground="#FAFAFA" FontFamily="{DynamicResource RiftFontMono}" />
                    <TextBlock Text="ALL TIME" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="GamesText" Text="0" FontSize="32" FontWeight="Bold" Foreground="#FAFAFA" FontFamily="{DynamicResource RiftFontMono}" />
                    <TextBlock Text="GAMES" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,2,0,0" />
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <!-- ═══ S2: Chart area + Top games as numbered list ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <!-- Chart: Last 14 Days -->
            <TextBlock Text="LAST 14 DAYS" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,10" />
            <ItemsControl x:Name="DailyChart">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2" Height="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DayLabel}" FontSize="11" Foreground="#444444" VerticalAlignment="Center" />
                            <Border Grid.Column="1" CornerRadius="3" Background="#08FFFFFF" Margin="0,2">
                                <Border CornerRadius="3" Background="#1AFFFFFF" HorizontalAlignment="Left" MinWidth="2" />
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding HoursText}" FontSize="11" Foreground="#666666" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{DynamicResource RiftFontMono}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Height="1" Background="#08FFFFFF" Margin="0,16,0,16" />

            <!-- Top games — numbered list -->
            <TextBlock Text="MOST PLAYED" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,10" />
            <ItemsControl x:Name="TopGamesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#FAFAFA" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" FontSize="11" Foreground="#333333" Margin="8,0">
                                <Run Text="{Binding SessionCount}" /><Run Text=" sessions" />
                            </TextBlock>
                            <TextBlock Grid.Column="2" Text="{Binding TotalTimeText}" FontSize="13" FontWeight="SemiBold" Foreground="#666666" HorizontalAlignment="Right" FontFamily="{DynamicResource RiftFontMono}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- ═══ S3: Recent sessions — compact rows ═══ -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="RECENT SESSIONS" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,10" />
            <ItemsControl x:Name="SessionsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2" Height="22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding GameName}" FontSize="12" Foreground="#FAFAFA" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding DateText}" FontSize="10" Foreground="#333333" Margin="8,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontSize="12" Foreground="#666666" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{DynamicResource RiftFontMono}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</ui:UiPage>

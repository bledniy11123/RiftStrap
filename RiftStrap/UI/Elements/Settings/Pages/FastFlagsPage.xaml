<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.FastFlagsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:RiftStrap.UI.ViewModels"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:resources="clr-namespace:RiftStrap.Resources"
      xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DesignHeight="1500" d:DesignWidth="800"
      Title="FastFlagsPage"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- "Control Panel" staggered entrance: 3 sections, 80ms offset -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Title + accent line + profile selector row + toggle ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <!-- Title -->
            <TextBlock Text="FastFlags" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="Engine settings and optimization presets" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Profile selector — compact inline row -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="PROFILE" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                <ComboBox x:Name="ProfileCombo" Grid.Column="1" Margin="0,0,8,0"
                          DisplayMemberPath="Name" SelectionChanged="ProfileCombo_Changed" />
                <rift:RiftButton Grid.Column="2" Content="Save Current" Variant="Secondary" Padding="10,6" FontSize="11" Click="SaveProfile_Click" Margin="0,0,4,0" />
                <rift:RiftButton Grid.Column="3" Content="Load" Variant="Primary" Padding="10,6" FontSize="11" Click="LoadProfile_Click" Margin="0,0,4,0" />
                <rift:RiftButton Grid.Column="4" Content="Delete" Variant="Ghost" Padding="10,6" FontSize="11" Click="DeleteProfile_Click" />
            </Grid>

            <!-- Thin divider -->
            <Border Height="1" Background="#08FFFFFF" Margin="0,14,0,14" />

            <!-- Manager toggle — inline row with subtle border -->
            <Border BorderBrush="#08FFFFFF" BorderThickness="1" CornerRadius="8" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Static resources:Strings.Menu_FastFlags_ManagerEnabled_Title}" FontSize="13" Foreground="#FAFAFA" />
                        <TextBlock Text="{x:Static resources:Strings.Menu_FastFlags_ManagerEnabled_Description}" FontSize="11" Foreground="#444444" Margin="0,2,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding UseFastFlagManager, Mode=TwoWay}" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <TextBlock Margin="0,12,0,0" Text="{x:Static resources:Strings.Menu_FastFlags_Description}" FontSize="12" Foreground="#444444" TextWrapping="Wrap" />
        </StackPanel>

        <!-- ═══ S2: Presets as 2-column grid (label left, control right) ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <!-- Section label -->
            <TextBlock Text="RENDERING" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,10" />
            <controls:MarkdownTextBlock MarkdownText="{Binding Source={x:Static resources:Strings.Menu_FastFlags_Presets_D3DExclusiveFullscreenInfo}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://riftstrap.com/wiki/features/engine-settings/#exclusive-fullscreen'}" Foreground="#444444" FontSize="11" Margin="0,0,0,12" />

            <!-- Preset rows: label left, control right -->
            <Grid Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <!-- MSAA -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static resources:Strings.Menu_FastFlags_Presets_MSAA_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding MSAALevels.Keys, Mode=OneTime}" Text="{Binding SelectedMSAALevel, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

                <!-- Fix Display Scaling -->
                <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_FastFlags_Presets_FixDisplayScaling_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_FastFlags_Presets_FixDisplayScaling_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Row="2" Grid.Column="1" IsChecked="{Binding FixDisplayScaling, Mode=TwoWay}" HorizontalAlignment="Right" VerticalAlignment="Center" />

                <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

                <!-- Rendering Mode -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static resources:Strings.Menu_FastFlags_Presets_RenderingMode_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ComboBox Grid.Row="4" Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding RenderingModes.Keys, Mode=OneTime}" Text="{Binding SelectedRenderingMode, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Border Grid.Row="5" Grid.ColumnSpan="2" Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

                <!-- Texture Quality -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static resources:Strings.Menu_FastFlags_Presets_TextureQuality_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ComboBox Grid.Row="6" Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding TextureQualities.Keys, Mode=OneTime}" Text="{Binding SelectedTextureQuality, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Border Grid.Row="7" Grid.ColumnSpan="2" Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

                <!-- Reset -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="{x:Static resources:Strings.Menu_FastFlags_Reset_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ui:ToggleSwitch Grid.Row="8" Grid.Column="1" IsChecked="{Binding ResetConfiguration, Mode=TwoWay}" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>

        <!-- ═══ S3: "Open Editor" link at bottom ═══ -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></StackPanel.RenderTransform>

            <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,16" />
            <TextBlock Margin="0,0,0,0">
                <Hyperlink TextDecorations="None" Command="{Binding OpenFastFlagEditorCommand}" Foreground="#666666">
                    <Run Text="{x:Static resources:Strings.Menu_FastFlagEditor_Title}" />
                    <Run Text=" &#x2192;" />
                </Hyperlink>
            </TextBlock>
            <TextBlock Text="{x:Static resources:Strings.Menu_FastFlags_Editor_Description}" FontSize="11" Foreground="#333333" Margin="0,2,0,0" Visibility="{Binding CanShowFastFlagEditor}" />
        </StackPanel>
    </Grid>
</ui:UiPage>

<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.ModsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:RiftStrap.UI.ViewModels"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:resources="clr-namespace:RiftStrap.Resources"
      xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
      xmlns:dmodels="clr-namespace:RiftStrap.UI.ViewModels.Settings"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance dmodels:ModsViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="800" d:DesignWidth="800"
      Title="ModsPage"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- File Manager: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Title + accent line + horizontal strip actions ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="Mods" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="Manage Roblox content modifications" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Actions as horizontal strip buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                <rift:RiftButton x:Name="OpenModFolderCardAction" Content="{x:Static resources:Strings.Menu_Mods_OpenModsFolder_Title}"
                                 Variant="Secondary" Padding="14,8" FontSize="12" Margin="0,0,6,0"
                                 Command="{Binding OpenModsFolderCommand}" />
                <rift:RiftButton Content="{x:Static resources:Strings.Common_Help}"
                                 Variant="Ghost" Padding="14,8" FontSize="12" Margin="0,0,6,0"
                                 Command="models:GlobalViewModel.OpenWebpageCommand" CommandParameter="https://riftstrap.com/wiki/features/modding/" />
                <rift:RiftButton Content="{x:Static resources:Strings.Menu_Mods_Misc_CompatibilitySettings_Title}"
                                 Variant="Ghost" Padding="14,8" FontSize="12"
                                 Command="{Binding OpenCompatSettingsCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- ═══ S2: Presets — grouped with thin dividers ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="PRESETS" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,12" />

            <!-- Mouse Cursor -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Presets_MouseCursor_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Presets_MouseCursor_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ComboBox Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding CursorTypeTask.Selections, Mode=OneTime}" Text="{Binding CursorTypeTask.NewState, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,12,0,12" />

            <!-- Old Avatar Editor — compact toggle row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Presets_OldAvatarEditor_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Presets_OldAvatarEditor_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding OldAvatarBackgroundTask.NewState, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,12,0,12" />

            <!-- Old Character Sounds -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Presets_OldCharacterSounds_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Presets_OldCharacterSounds_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding OldCharacterSoundsTask.NewState, Mode=TwoWay}" VerticalAlignment="Center" />
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,12,0,12" />

            <!-- Emoji Type -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Presets_EmojiType_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Presets_EmojiType_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ComboBox Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding EmojiFontTask.Selections, Mode=OneTime}" Text="{Binding EmojiFontTask.NewState, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </StackPanel>

        <!-- ═══ S3: Miscellaneous ═══ -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="MISCELLANEOUS" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,12" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.Menu_Mods_Misc_CustomFont_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Icon="DocumentAdd16" Content="{x:Static resources:Strings.Menu_Mods_Misc_CustomFont_Choose}" Command="{Binding ManageCustomFontCommand}" Visibility="{Binding ChooseCustomFontVisibility, Mode=OneWay}" Margin="0,0,4,0" />
                    <ui:Button Icon="Delete16" Content="{x:Static resources:Strings.Menu_Mods_Misc_CustomFont_Remove}" Appearance="Danger" Command="{Binding ManageCustomFontCommand}" Visibility="{Binding DeleteCustomFontVisibility, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</ui:UiPage>

<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.AccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True" Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- S1: Title with accent line + Add button — "Profile Stack" -->
        <Grid x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <Grid.RenderTransform><TranslateTransform x:Name="S1T" /></Grid.RenderTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Accounts" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
            <Border Grid.Column="1" Width="32" Height="2" Background="#333333" VerticalAlignment="Center" Margin="14,2,0,0" CornerRadius="1" />
            <rift:RiftButton Grid.Column="3" Content="Add Account" Variant="Primary" Click="AddAccount_Click" VerticalAlignment="Center" />
        </Grid>

        <!-- S2: Accounts as horizontal profile cards (avatar + name stack) -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="S2T" /></Grid.RenderTransform>

            <ItemsControl x:Name="AccountsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Margin="0,0,10,10" Padding="14,14" CornerRadius="10" Cursor="Hand"
                                Background="#06FFFFFF" MouseLeftButtonUp="AccountCard_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Avatar circle -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0"
                                        ClipToBounds="True" VerticalAlignment="Center" Background="#0AFFFFFF">
                                    <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>

                                <!-- Name stack -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Active indicator as dot next to name -->
                                        <Ellipse x:Name="ActiveBadge" Width="6" Height="6" Fill="{DynamicResource RiftAccentBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" Visibility="Collapsed" />
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock FontSize="10" Foreground="#444444" Margin="0,2,0,0">
                                        <Run Text="@" /><Run Text="{Binding Username}" />
                                    </TextBlock>
                                </StackPanel>

                                <!-- Remove -->
                                <rift:RiftButton Grid.Column="2" Content="X" Variant="Ghost" Padding="5,3" FontSize="10"
                                                 Click="RemoveAccount_Click" Tag="{Binding UserId}" VerticalAlignment="Top" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- S3: Empty state -->
        <StackPanel x:Name="S3" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3T" /></StackPanel.RenderTransform>
            <TextBlock Text="No accounts" FontSize="15" FontWeight="Medium" Foreground="#555555" HorizontalAlignment="Center" />
            <TextBlock Text="Add your Roblox cookie to switch accounts quickly" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,6,0,0" />
        </StackPanel>
    </Grid>
</ui:UiPage>

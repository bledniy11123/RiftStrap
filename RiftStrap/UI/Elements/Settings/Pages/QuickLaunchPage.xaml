<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.QuickLaunchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True" Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S4" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.24" />
            <DoubleAnimation Storyboard.TargetName="S4T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.24">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- S1: Big search input at top — NO title, search IS the page ("Spotlight" style) -->
        <Grid x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,8,0,22">
            <Grid.RenderTransform><TranslateTransform x:Name="S1T" /></Grid.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox x:Name="SearchBox" PlaceholderText="Search games..." FontSize="16" Padding="14,12" Margin="0,0,10,0" KeyDown="Search_KeyDown" />
                <rift:RiftButton Grid.Column="1" Content="Search" Variant="Primary" Click="Search_Click" Padding="18,12" FontSize="13" />
            </Grid>
        </Grid>

        <!-- S2: Search results as horizontal list -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <Grid.RenderTransform><TranslateTransform x:Name="S2T" /></Grid.RenderTransform>
        <ItemsControl x:Name="SearchResults" Visibility="Collapsed">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="150" Margin="0,0,8,0" Padding="10" CornerRadius="8" Cursor="Hand"
                            Background="#06FFFFFF">
                        <StackPanel>
                            <Border Height="70" CornerRadius="6" Margin="0,0,0,8" Background="#04FFFFFF" ClipToBounds="True">
                                <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#EEEEEE" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="9" Foreground="#444444" Margin="0,2,0,6">
                                <Run Text="{Binding PlayingText}" /><Run Text=" playing" />
                            </TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <rift:RiftButton Content="Play" Variant="Primary" Padding="8,3" FontSize="10" Click="PlayGame_Click" Tag="{Binding PlaceId}" />
                                <rift:RiftButton Grid.Column="1" Content="+" Variant="Ghost" Padding="5,3" FontSize="10" Click="FavoriteGame_Click" Tag="{Binding PlaceId}" ToolTip="Add to favorites" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </Grid>

        <!-- S3: Favorites as small chips -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0" Margin="0,0,0,18">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3T" /></StackPanel.RenderTransform>

            <TextBlock Text="FAVORITES" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" Margin="0,0,0,8" />

            <ItemsControl x:Name="FavoritesList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Chip style — compact rounded pill -->
                        <Border Margin="0,0,6,6" Padding="10,5" CornerRadius="12" Cursor="Hand"
                                Background="#08FFFFFF" MouseLeftButtonUp="FavCard_Click">
                            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Medium" Foreground="#CCCCCC" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- S4: Recent as dim text rows -->
        <StackPanel x:Name="S4" Grid.Row="3" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S4T" /></StackPanel.RenderTransform>

            <TextBlock Text="RECENT" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" Margin="0,0,0,8" />

            <ItemsControl x:Name="RecentList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Grid Margin="0,6,0,6" Cursor="Hand" MouseLeftButtonUp="RecentCard_Click">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#555555" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding LastPlayed}" FontSize="10" Foreground="#333333" VerticalAlignment="Center" />
                            </Grid>
                            <Border Height="1" Background="#06FFFFFF" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</ui:UiPage>

<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.CommunityHubPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True" Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- S1: Title with accent line + Refresh — "Store" style -->
        <Grid x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,14">
            <Grid.RenderTransform><TranslateTransform x:Name="S1T" /></Grid.RenderTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Community Hub" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
            <Border Grid.Column="1" Width="32" Height="2" Background="#333333" VerticalAlignment="Center" Margin="14,2,0,0" CornerRadius="1" />
            <rift:RiftButton Grid.Column="3" Content="Refresh" Variant="Ghost" Click="Refresh_Click" VerticalAlignment="Center" />
        </Grid>

        <!-- S2: Search inline + category pills — no card wrapper -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,18">
            <Grid.RenderTransform><TranslateTransform x:Name="S2T" /></Grid.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox x:Name="SearchBox" PlaceholderText="Search themes..." Margin="0,0,10,0" KeyUp="Search_KeyUp" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <rift:RiftButton Content="All" Variant="Secondary" Tag="All" Click="Category_Click" Padding="10,5" FontSize="11" Margin="0,0,4,0" />
                    <rift:RiftButton Content="Cursors" Variant="Ghost" Tag="Cursors" Click="Category_Click" Padding="10,5" FontSize="11" Margin="0,0,4,0" />
                    <rift:RiftButton Content="Textures" Variant="Ghost" Tag="Textures" Click="Category_Click" Padding="10,5" FontSize="11" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="#08FFFFFF" VerticalAlignment="Bottom" Margin="0,8,0,0" />
        </Grid>

        <!-- S3: Theme cards — image-forward (preview takes 60% of card height) -->
        <Grid x:Name="S3" Grid.Row="2" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="S3T" /></Grid.RenderTransform>

            <ItemsControl x:Name="ThemesList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="210" Margin="0,0,10,10" CornerRadius="10" Cursor="Hand"
                                Background="#06FFFFFF" ClipToBounds="True">
                            <StackPanel>
                                <!-- Preview area — 60% of ~200px total = ~120px -->
                                <Border Height="120" Background="#04FFFFFF">
                                    <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="14" FontWeight="SemiBold" Foreground="#333333" />
                                </Border>

                                <!-- Info area — compact -->
                                <StackPanel Margin="12,10,12,12">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="10" Foreground="#444444" Margin="0,3,0,0">
                                        <Run Text="by " /><Run Text="{Binding Author}" />
                                    </TextBlock>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="10" Foreground="#333333" VerticalAlignment="Center">
                                            <Run Text="{Binding DownloadsText}" /><Run Text=" downloads" />
                                        </TextBlock>
                                        <rift:RiftButton Grid.Column="1" Content="Install" Variant="Primary" Padding="10,4" FontSize="11" Click="Install_Click" Tag="{Binding Id}" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock x:Name="StatusText" Text="Loading..." HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="13" Foreground="#444444" />
        </Grid>
    </Grid>
</ui:UiPage>

<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.PluginsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True" Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- Extensions: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Title + accent line + "Open Folder" link ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="Plugins" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="Extend RiftStrap with community plugins" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- "Open Folder" as a text link, not a button -->
            <TextBlock>
                <Hyperlink TextDecorations="None" Click="OpenFolder_Click" Foreground="#666666">
                    <Run Text="Open Plugins Folder" />
                    <Run Text=" &#x2192;" />
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- ═══ S2: Plugin rows with name/version/author — or empty state ═══ -->
        <Grid x:Name="S2" Grid.Row="1" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></Grid.RenderTransform>

            <StackPanel>
                <TextBlock Text="INSTALLED" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,10" />

                <ItemsControl x:Name="PluginsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,0" Height="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Manifest.Name}" FontSize="13" FontWeight="SemiBold" Foreground="#FAFAFA" />
                                        <TextBlock FontSize="11" Foreground="#333333" Margin="8,1,0,0" VerticalAlignment="Center">
                                            <Run Text="v" /><Run Text="{Binding Manifest.Version}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="#444444" Margin="0,1,0,0">
                                        <Run Text="by " /><Run Text="{Binding Manifest.Author}" />
                                    </TextBlock>
                                </StackPanel>
                                <rift:RiftButton Grid.Column="1" Content="Unload" Variant="Ghost" Padding="10,6" FontSize="11" Click="Unload_Click" Tag="{Binding Manifest.Id}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Empty state — minimal -->
            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="No plugins installed" FontSize="15" Foreground="#666666" HorizontalAlignment="Center" />
                <TextBlock Text="Place plugin folders in the Plugins directory" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:UiPage>

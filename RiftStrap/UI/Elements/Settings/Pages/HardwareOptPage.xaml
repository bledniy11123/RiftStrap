<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.HardwareOptPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S4" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.24" />
            <DoubleAnimation Storyboard.TargetName="S4T" Storyboard.TargetProperty="Y" From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.24">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- S1: Title with accent line — "Diagnostic Panel" feel -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,22">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1T" /></StackPanel.RenderTransform>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Hardware Optimizer" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <Border Width="32" Height="2" Background="#333333" VerticalAlignment="Center" Margin="14,2,0,0" CornerRadius="1" />
            </StackPanel>
            <TextBlock Text="Auto-detect your hardware and optimize Roblox performance" FontSize="12" Foreground="#444444" Margin="0,6,0,0" />
        </StackPanel>

        <!-- S2: 2x2 grid — no icon boxes, just label + big value (diagnostic readout) -->
        <UniformGrid x:Name="S2" Grid.Row="1" Rows="2" Columns="2" Opacity="0" Margin="0,0,0,20">
            <UniformGrid.RenderTransform><TranslateTransform x:Name="S2T" /></UniformGrid.RenderTransform>

            <!-- CPU -->
            <StackPanel Margin="0,0,24,18">
                <TextBlock Text="CPU" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" />
                <TextBlock x:Name="CpuText" Text="Detecting..." FontSize="20" FontWeight="SemiBold" Foreground="#FAFAFA" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="CpuCoresText" Text="" FontSize="11" Foreground="#444444" Margin="0,2,0,0" />
            </StackPanel>

            <!-- GPU -->
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="GPU" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" />
                <TextBlock x:Name="GpuText" Text="Detecting..." FontSize="20" FontWeight="SemiBold" Foreground="#FAFAFA" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="GpuVramText" Text="" FontSize="11" Foreground="#444444" Margin="0,2,0,0" />
            </StackPanel>

            <!-- RAM -->
            <StackPanel Margin="0,0,24,0">
                <TextBlock Text="RAM" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" />
                <TextBlock x:Name="RamText" Text="Detecting..." FontSize="20" FontWeight="SemiBold" Foreground="#FAFAFA" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Display -->
            <StackPanel>
                <TextBlock Text="DISPLAY" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" />
                <TextBlock x:Name="DisplayText" Text="Detecting..." FontSize="20" FontWeight="SemiBold" Foreground="#FAFAFA" Margin="0,4,0,0" />
            </StackPanel>
        </UniformGrid>

        <!-- S3: Tier as colored text (not boxed) + flags preview as monospace list -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3T" /></StackPanel.RenderTransform>

            <!-- Thin divider -->
            <Border Height="1" Background="#0CFFFFFF" Margin="0,0,0,16" />

            <!-- Tier badge as plain colored text -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="TIER" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock x:Name="TierText" Text="--" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource RiftAccentBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="TierDescription" Text="" FontSize="12" Foreground="#555555" Margin="0,4,0,0" TextWrapping="Wrap" />
            <TextBlock x:Name="FlagCountText" Text="" FontSize="11" Foreground="#333333" Margin="0,6,0,12" />

            <!-- Flags as monospace list with dim background -->
            <Border CornerRadius="8" Padding="14,12" Background="#06FFFFFF">
                <StackPanel>
                    <TextBlock Text="RECOMMENDED FLAGS" FontSize="9" Foreground="#2A2A2A" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ItemsControl x:Name="FlagsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Key}" FontSize="11" Foreground="#555555" FontFamily="{DynamicResource RiftFontMono}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" Foreground="#CCCCCC" FontFamily="{DynamicResource RiftFontMono}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- S4: Apply button prominent at bottom -->
        <StackPanel x:Name="S4" Grid.Row="3" Opacity="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S4T" /></StackPanel.RenderTransform>
            <rift:RiftButton x:Name="ApplyButton" Content="Apply Optimization" Variant="Primary" Click="Apply_Click" Margin="0,0,10,0" Padding="20,10" FontSize="13" />
            <rift:RiftButton Content="Re-detect" Variant="Ghost" Click="Redetect_Click" Padding="14,10" FontSize="12" />
        </StackPanel>
    </Grid>
</ui:UiPage>

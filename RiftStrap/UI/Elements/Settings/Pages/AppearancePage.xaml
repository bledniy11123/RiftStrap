<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.AppearancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:RiftStrap.UI.ViewModels"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
      xmlns:resources="clr-namespace:RiftStrap.Resources"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="800"
      Title="AppearancePage"
      Scrollable="True"
      Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- Preferences: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Title + Theme/Language group ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="Appearance" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
            <TextBlock Text="Customize how RiftStrap looks" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
            <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FAFAFA" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Group: THEME, LANGUAGE -->
            <TextBlock Text="THEME &amp; LANGUAGE" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,12" />

            <!-- Row: Theme -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_Global_Theme_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding Themes, Mode=OneTime}" Text="{Binding Theme, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,10,0,10" />

            <!-- Row: Language -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_Language_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_Language_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ComboBox Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding Languages, Mode=OneTime}" Text="{Binding SelectedLanguage, Mode=TwoWay}" />
            </Grid>
        </StackPanel>

        <!-- ═══ S2: Style, Icon ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="STYLE &amp; ICON" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,12" />

            <!-- Row: Bootstrapper Style + Preview -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_Bootstrapper_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_Bootstrapper_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ComboBox Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding Dialogs, Mode=OneTime}" Text="{Binding Dialog, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <rift:RiftButton Grid.Column="2" Content="{x:Static resources:Strings.Menu_Appearance_Preview}" Variant="Ghost" Padding="10,6" FontSize="11" Margin="8,0,0,0" Command="{Binding PreviewBootstrapperCommand}" />
            </Grid>

            <!-- Custom themes expander -->
            <ui:CardExpander Margin="0,12,0,0" IsExpanded="{Binding Path=CustomThemesExpanded, Mode=OneWay}" Style="{StaticResource NoUserExpansionCardExpanderStyle}">
                <ui:CardExpander.Header>
                    <StackPanel>
                        <TextBlock FontSize="13" Text="{x:Static resources:Strings.Menu_Appearance_Style_Title}" Foreground="#FAFAFA" />
                        <TextBlock FontSize="11" Text="{x:Static resources:Strings.Menu_Appearance_Style_Description}" Foreground="#444444" />
                    </StackPanel>
                </ui:CardExpander.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="CustomThemesListBox" Height="265" Grid.Row="0" Grid.Column="0" Margin="0,0,4,0" ItemsSource="{Binding CustomThemes, Mode=OneWay}" SelectionChanged="CustomThemeSelection" SelectedIndex="{Binding SelectedCustomThemeIndex, Mode=TwoWay}" />
                    <Grid Grid.Row="1" Grid.Column="0" Margin="0,8,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Margin="0,0,4,0" Icon="Add28" Content="{x:Static resources:Strings.Common_New}" HorizontalAlignment="Stretch" Command="{Binding AddCustomThemeCommand, Mode=OneTime}" />
                        <ui:Button Grid.Column="1" Margin="4,0,0,0" Icon="Delete28" Content="{x:Static resources:Strings.Common_Delete}" HorizontalAlignment="Stretch" Appearance="Danger" IsEnabled="{Binding IsCustomThemeSelected, Mode=OneWay}" Command="{Binding DeleteCustomThemeCommand, Mode=OneTime}" />
                    </Grid>
                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="4,0,0,0">
                        <StackPanel.Style>
                            <Style>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCustomThemeSelected}" Value="False">
                                        <Setter Property="StackPanel.Visibility" Value="Hidden"></Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{x:Static resources:Strings.Common_Name}" Foreground="#444444" FontSize="11" />
                        <ui:TextBox Margin="0,4,0,0" Text="{Binding SelectedCustomThemeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Margin="0,0,4,0" Icon="Edit28" Content="{x:Static resources:Strings.Common_Rename}" HorizontalAlignment="Stretch" Command="{Binding RenameCustomThemeCommand, Mode=OneTime}" />
                            <ui:Button Grid.Column="1" Margin="4,0,4,0" Icon="DesktopEdit24" Content="{x:Static resources:Strings.Common_Edit}" HorizontalAlignment="Stretch" Command="{Binding EditCustomThemeCommand, Mode=OneTime}" />
                            <ui:Button Grid.Column="2" Margin="4,0,0,0" Icon="ArrowExportRtl24" Content="{x:Static resources:Strings.Common_Export}" HorizontalAlignment="Stretch" Command="{Binding ExportCustomThemeCommand, Mode=OneTime}" />
                        </Grid>
                    </StackPanel>
                    <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="{x:Static resources:Strings.Menu_Appearance_CustomThemes_NoneSelected}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#444444">
                        <TextBlock.Style>
                            <Style>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCustomThemeSelected}" Value="True">
                                        <Setter Property="TextBlock.Visibility" Value="Hidden"></Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </ui:CardExpander>

            <Border Height="1" Background="#08FFFFFF" Margin="0,14,0,14" />

            <!-- Row: Icon -->
            <Grid x:Name="IconSelector">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_Icon_Title}" FontSize="13" Foreground="#FAFAFA" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_Icon_Description}" FontSize="11" Foreground="#444444" TextWrapping="Wrap" />
                </StackPanel>
                <ComboBox Grid.Column="1" Padding="10,5,10,5" ItemsSource="{Binding Icons, Mode=OneWay}" SelectedValuePath="IconType" SelectedValue="{Binding Icon, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image Height="16" Source="{Binding ImageSource, Mode=OneWay}" RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding Path=IconType, Converter={StaticResource EnumNameConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </StackPanel>

        <!-- ═══ S3: Customization ═══ -->
        <StackPanel x:Name="S3" Grid.Row="2" Opacity="0">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="CUSTOMIZATION" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,12" />

            <!-- Title row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_CustomisationTitle_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1">
                    <ui:TextBox Text="{Binding Title, Mode=TwoWay}" />
                    <TextBlock Margin="0,4,0,0" FontSize="10" Text="{x:Static resources:Strings.Menu_Appearance_CustomisationTitle_Description}" Foreground="#333333" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,12,0,12" />

            <!-- Custom icon row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static resources:Strings.Menu_Appearance_CustomisationIcon_Title}" FontSize="13" Foreground="#FAFAFA" VerticalAlignment="Center" TextWrapping="Wrap" />
                <StackPanel Grid.Column="1">
                    <ui:TextBox Margin="0,0,4,0" Text="{Binding CustomIconLocation, Mode=TwoWay}" />
                    <TextBlock Margin="0,4,0,0" FontSize="10" Text="{x:Static resources:Strings.Menu_Appearance_CustomisationIcon_Description}" Foreground="#333333" TextWrapping="Wrap" />
                </StackPanel>
                <ui:Button Grid.Column="2" Margin="4,0,0,0" Height="35" Icon="Folder24" Content="{x:Static resources:Strings.Common_Browse}" Command="{Binding BrowseCustomIconLocationCommand}" VerticalAlignment="Top" />
            </Grid>
        </StackPanel>
    </Grid>
</ui:UiPage>

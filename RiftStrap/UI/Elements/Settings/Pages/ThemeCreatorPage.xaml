<ui:UiPage x:Class="RiftStrap.UI.Elements.Settings.Pages.ThemeCreatorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
      Scrollable="True" Loaded="OnPageLoaded">

    <ui:UiPage.Resources>
        <!-- Workshop: staggered entrance -->
        <Storyboard x:Key="SectionEntrance">
            <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="S1Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="S2Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="S3Slide" Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.5" BeginTime="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiPage.Resources>

    <Grid Margin="8,0,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ S1: Title + accent line + Export button inline ═══ -->
        <StackPanel x:Name="S1" Grid.Row="0" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S1Slide" Y="18" /></StackPanel.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Theme Creator" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA" />
                    <TextBlock Text="Create your own in-game theme" FontSize="13" Foreground="#444444" Margin="0,5,0,0" />
                    <Border Width="40" Height="2" CornerRadius="1" HorizontalAlignment="Left" Margin="0,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FAFAFA" Offset="0" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>
                <rift:RiftButton Grid.Column="1" Content="Export .rifttheme" Variant="Primary" Click="Export_Click" VerticalAlignment="Top" Padding="16,8" FontSize="12" />
            </Grid>
        </StackPanel>

        <!-- ═══ S2: Theme info as inline fields (no card) ═══ -->
        <StackPanel x:Name="S2" Grid.Row="1" Opacity="0" Margin="0,0,0,20">
            <StackPanel.RenderTransform><TranslateTransform x:Name="S2Slide" Y="18" /></StackPanel.RenderTransform>

            <TextBlock Text="THEME INFO" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,12" />

            <!-- Inline fields row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="NAME" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="ThemeNameBox" PlaceholderText="My Theme" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="AUTHOR" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="AuthorBox" PlaceholderText="Your name" />
                </StackPanel>
                <StackPanel Grid.Column="4" VerticalAlignment="Bottom" MinWidth="80">
                    <TextBlock Text="FILES" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock x:Name="ReplacementCount" Text="0 files" FontSize="18" FontWeight="Bold" Foreground="#FAFAFA" FontFamily="{DynamicResource RiftFontMono}" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="#08FFFFFF" Margin="0,16,0,14" />

            <!-- Category tabs as pills -->
            <StackPanel Orientation="Horizontal">
                <rift:RiftButton Content="Cursors" Variant="Secondary" Tag="Cursors" Click="Category_Click" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                <rift:RiftButton Content="Textures" Variant="Ghost" Tag="Textures" Click="Category_Click" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                <rift:RiftButton Content="Fonts" Variant="Ghost" Tag="Fonts" Click="Category_Click" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                <rift:RiftButton Content="Sounds" Variant="Ghost" Tag="Sounds" Click="Category_Click" Padding="12,6" FontSize="12" />
            </StackPanel>
        </StackPanel>

        <!-- ═══ S3: File browser as compact rows ═══ -->
        <Grid x:Name="S3" Grid.Row="2" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="S3Slide" Y="18" /></Grid.RenderTransform>

            <StackPanel>
                <TextBlock Text="FILES" FontSize="9" Foreground="#2A2A2A" FontWeight="Bold" Margin="0,0,0,8" />

                <ItemsControl x:Name="FilesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,0" Height="40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="#FAFAFA" FontFamily="Consolas, Cascadia Mono, monospace" />
                                    <TextBlock Text="{Binding RelativePath}" FontSize="9" Foreground="#333333" TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                </StackPanel>
                                <rift:RiftButton Grid.Column="1" Content="{Binding IsReplaced, Converter={x:Null}}"
                                                 Variant="Secondary" Padding="10,5" FontSize="11"
                                                 Click="ReplaceFile_Click" Tag="{Binding RelativePath}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <TextBlock x:Name="ScanStatus" Text="Click a category to scan Roblox content"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="13" Foreground="#444444" />
        </Grid>
    </Grid>
</ui:UiPage>

<base:WpfUiWindow
    x:Class="RiftStrap.UI.Elements.Editor.BootstrapperEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dmodels="clr-namespace:RiftStrap.UI.ViewModels.Editor"
    xmlns:local="clr-namespace:RiftStrap.UI.Elements.Editor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:RiftStrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{Binding Path=Title, Mode=OneTime}"
    Width="1000"
    Height="500"
    d:DataContext="{d:DesignInstance dmodels:BootstrapperEditorWindowViewModel,
                                     IsDesignTimeCreatable=True}"
    Background="#FF080808"
    Closing="OnClosing"
    ExtendsContentIntoTitleBar="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Dark background -->
        <Border Grid.RowSpan="3">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#080808" Offset="0" />
                    <GradientStop Color="#0A0A0A" Offset="0.3" />
                    <GradientStop Color="#090909" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Title bar -->
        <ui:TitleBar
            x:Name="RootTitleBar"
            Title="{Binding Path=Title, Mode=OneTime}"
            Grid.Row="0"
            Padding="8"
            ForceShutdown="False"
            Icon="pack://application:,,,/Resources/RiftLogo.png"
            MinimizeToTray="False"
            UseSnapLayout="True" />

        <!-- Editor area with border -->
        <Border Grid.Row="1" Margin="12,8,12,0" CornerRadius="6" BorderBrush="#0CFFFFFF" BorderThickness="1"
                Background="#060606" ClipToBounds="True">
            <avalonedit:TextEditor
                x:Name="UIXML"
                Margin="0"
                Padding="8,6"
                ShowLineNumbers="True"
                Style="{StaticResource NewTextEditor}"
                SyntaxHighlighting="XML"
                Background="Transparent" />
        </Border>

        <!-- Bottom action bar -->
        <Border Grid.Row="2" Margin="12,8,12,12" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Open theme folder (left) -->
                <ui:Button Grid.Column="0"
                    Command="{Binding Path=OpenThemeFolderCommand, Mode=OneTime}"
                    Content="{x:Static resources:Strings.CustomTheme_Editor_OpenThemeDirectory}" />

                <!-- Preview + Save (right) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:Button Margin="0,0,6,0"
                        Command="{Binding Path=PreviewCommand, Mode=OneTime}"
                        Content="{x:Static resources:Strings.CustomTheme_Editor_Preview}" />

                    <ui:Button Appearance="Primary"
                        Command="{Binding Path=SaveCommand, Mode=OneTime}"
                        Content="{x:Static resources:Strings.CustomTheme_Editor_Save}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Snackbar -->
        <ui:Snackbar
            x:Name="Snackbar"
            Grid.RowSpan="3"
            Margin="200,0,200,20"
            Panel.ZIndex="9"
            Timeout="3000" />
    </Grid>
</base:WpfUiWindow>

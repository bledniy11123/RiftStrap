<UserControl x:Class="RiftStrap.UI.Elements.Controls.Expander"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:RiftStrap.UI.Elements.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="Control">
    <Border CornerRadius="6" Background="#06FFFFFF" Margin="0,6,0,0">
        <Expander VerticalAlignment="Top" IsExpanded="{Binding IsExpanded, ElementName=Control}"
                  Content="{Binding InnerContent, ElementName=Control}"
                  Background="Transparent" BorderThickness="0">
            <Expander.Header>
                <Grid Margin="2,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center"
                                   Symbol="{Binding HeaderIcon, ElementName=Control}"
                                   FontSize="16" Foreground="#888888" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="#CCCCCC"
                               Text="{Binding HeaderText, ElementName=Control}" />
                </Grid>
            </Expander.Header>
        </Expander>
    </Border>
</UserControl>

<base:WpfUiWindow x:Class="RiftStrap.UI.Elements.Dialogs.LanguageSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:RiftStrap.UI.Elements.Dialogs"
        xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
        xmlns:resources="clr-namespace:RiftStrap.Resources"
        xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
        mc:Ignorable="d"
        Title="RiftStrap"
        MinWidth="0" MinHeight="0"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="16" Background="#0A0A0A"
            BorderThickness="1" BorderBrush="#1AFFFFFF"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Height="36">
                <Button HorizontalAlignment="Right" Content="✕" FontSize="10" Foreground="#666666"
                        Width="28" Height="28" Margin="0,6,8,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#30FF4444" />
                                    <Setter Property="Foreground" Value="#FF6666" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="28,0,28,28">
                <!-- Logo -->
                <Image Source="pack://application:,,,/Resources/RiftLogo.png"
                       Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,14"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <TextBlock Text="{x:Static resources:Strings.Dialog_LanguageSelector_Header}" FontSize="18" FontWeight="SemiBold"
                           Foreground="#FAFAFA" HorizontalAlignment="Center" />
                <TextBlock Text="{x:Static resources:Strings.Dialog_LanguageSelector_Subtext}" TextWrapping="Wrap"
                           Foreground="#555555" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,20" />

                <ComboBox ItemsSource="{Binding Languages, Mode=OneTime}" Text="{Binding SelectedLanguage, Mode=TwoWay}"
                          Margin="0,0,0,16" Padding="10,8" FontSize="13" />

                <rift:RiftButton Content="{x:Static resources:Strings.Common_OK}" Variant="Primary"
                                 HorizontalAlignment="Stretch" Padding="0,12"
                                 Command="{Binding SetLocaleCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</base:WpfUiWindow>

<base:WpfUiWindow x:Class="RiftStrap.UI.Elements.Dialogs.ConnectivityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
        xmlns:local="clr-namespace:RiftStrap.UI.Elements.Dialogs"
        xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
        xmlns:resources="clr-namespace:RiftStrap.Resources"
        xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
        mc:Ignorable="d"
        Width="480"
        MinHeight="0"
        SizeToContent="Height"
        Title="{x:Static resources:Strings.Dialog_Connectivity_Title}"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowBackdropType="None"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Storyboard x:Key="Entrance">
            <DoubleAnimation Storyboard.TargetName="ContentRoot" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentSlide" Storyboard.TargetProperty="Y"
                             From="14" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="ContentRoot" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentSlide" />
        </Grid.RenderTransform>

        <Border CornerRadius="16" BorderThickness="1" BorderBrush="#12FFFFFF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#080808" Offset="0" />
                    <GradientStop Color="#0E0E11" Offset="0.5" />
                    <GradientStop Color="#080808" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top light bleed -->
                <Border Grid.Row="0" Grid.RowSpan="3" CornerRadius="16,16,0,0" Height="80" VerticalAlignment="Top" IsHitTestVisible="False" Opacity="0.5">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,-0.2" RadiusX="0.8" RadiusY="0.6">
                            <GradientStop Color="#0AFFFFFF" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Header -->
                <Grid Grid.Row="0" Height="44">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Image Source="pack://application:,,,/Resources/RiftLogo.png" Width="28" Height="28" Margin="0,0,8,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="{x:Static resources:Strings.Dialog_Connectivity_Title}" FontSize="14" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Content="&#x2715;" FontSize="10" Foreground="#666666"
                            Width="28" Height="28" Margin="0,8,10,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Content -->
                <Grid Grid.Row="1" Margin="18,0,18,18">
                    <StackPanel>
                        <TextBlock x:Name="TitleTextBlock" Text="? is unable to connect to ?" FontSize="18" Foreground="#FAFAFA" TextWrapping="Wrap" />
                        <controls:MarkdownTextBlock x:Name="DescriptionTextBlock" MarkdownText="?" Margin="0,16,0,0" TextWrapping="Wrap" Foreground="#A0A0A0" />
                        <TextBlock Text="{x:Static resources:Strings.Dialog_Connectivity_MoreInfo}" Margin="0,16,0,0" TextWrapping="Wrap" Foreground="#888888" />
                        <Border CornerRadius="8" Margin="0,8,0,0" BorderBrush="#1AFFFFFF" BorderThickness="1" Background="#141414">
                            <RichTextBox x:Name="ErrorRichTextBox" Padding="8" Block.LineHeight="2"
                                         Background="Transparent" Foreground="#A0A0A0"
                                         FontFamily="JetBrains Mono, Cascadia Code, Consolas" FontSize="12"
                                         BorderThickness="0"
                                         IsReadOnly="True" />
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="2" CornerRadius="0,0,16,16" Padding="18,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#06FFFFFF" Offset="0" />
                            <GradientStop Color="#0AFFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight" HorizontalAlignment="Right">
                        <rift:RiftButton x:Name="CloseButton" MinWidth="100" Content="{x:Static resources:Strings.Common_Close}" Variant="Secondary" Padding="16,8" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>

<base:WpfUiWindow x:Class="RiftStrap.UI.Elements.Dialogs.LaunchMenuDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:RiftStrap.UI.Elements.Dialogs"
        xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
        xmlns:models="clr-namespace:RiftStrap.UI.ViewModels"
        xmlns:resources="clr-namespace:RiftStrap.Resources"
        xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
        mc:Ignorable="d"
        Title="RiftStrap"
        MinWidth="0" MinHeight="0"
        Width="400" Height="600"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowBackdropType="None"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <base:WpfUiWindow.Resources>
        <!-- Entrance animation for entire content -->
        <Storyboard x:Key="EntranceAnim">
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainContentTranslate" Storyboard.TargetProperty="Y"
                             From="16" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Logo glow pulse -->
        <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoGlow" Storyboard.TargetProperty="Opacity"
                             From="0.08" To="0.25" Duration="0:0:3">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Action card hover style -->
        <Style x:Key="ActionCardStyle" TargetType="Button">
            <Setter Property="Background" Value="#0AFFFFFF" />
            <Setter Property="Foreground" Value="#FAFAFA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#0AFFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="16,14">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#12FFFFFF" />
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#18FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#18FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </base:WpfUiWindow.Resources>

    <Border CornerRadius="16" ClipToBounds="True" BorderThickness="1" BorderBrush="#1AFFFFFF">
        <Grid>
            <!-- Animated gradient background -->
            <Border CornerRadius="16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A0A0A" Offset="0" />
                        <GradientStop Color="#0F0F12" Offset="0.5" />
                        <GradientStop Color="#0A0A0A" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Decorative top gradient stripe -->
            <Border CornerRadius="16,16,0,0" Height="120" VerticalAlignment="Top" IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#0CFFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Main content -->
            <Grid x:Name="MainContent" Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="MainContentTranslate" Y="16" />
                </Grid.RenderTransform>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Custom title bar -->
                <Grid Grid.Row="0" Height="40">
                    <TextBlock Text="{Binding Version, Mode=OneTime, StringFormat='v{0}'}" FontSize="10" Foreground="#333333"
                               VerticalAlignment="Center" Margin="18,0,0,0" />
                    <Button HorizontalAlignment="Right" Content="✕" FontSize="10" Foreground="#555555"
                            Width="28" Height="28" Margin="0,8,10,0" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                                        <Setter Property="Foreground" Value="#AAAAAA" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Logo + branding -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,8,0,28">
                    <Grid HorizontalAlignment="Center">
                        <!-- Glow behind logo -->
                        <Ellipse x:Name="LogoGlow" Width="180" Height="180" Opacity="0.1" IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#30FFFFFF" Offset="0" />
                                    <GradientStop Color="#00FFFFFF" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Image Source="pack://application:,,,/Resources/RiftLogo.png" Width="80" Height="80"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Grid>
                    <TextBlock Text="RiftStrap" FontSize="22" FontWeight="SemiBold" Foreground="#FAFAFA"
                               HorizontalAlignment="Center" Margin="0,14,0,0" />
                    <TextBlock Text="Your Roblox, elevated" FontSize="12" Foreground="#555555"
                               HorizontalAlignment="Center" Margin="0,3,0,0" />
                </StackPanel>

                <!-- Action cards -->
                <StackPanel Grid.Row="2" Margin="24,0,24,0">
                    <!-- Launch Roblox -->
                    <Button Style="{StaticResource ActionCardStyle}" Command="{Binding LaunchRobloxCommand, Mode=OneTime}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8" Background="#0CFFFFFF" Margin="0,0,14,0">
                                <TextBlock Text="▶" FontSize="16" Foreground="#FAFAFA" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resources:Strings.LaunchMenu_LaunchRoblox}" FontSize="14" FontWeight="SemiBold" Foreground="#FAFAFA" />
                                <TextBlock Text="Start playing" FontSize="11" Foreground="#555555" Margin="0,1,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="→" FontSize="16" Foreground="#333333" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <!-- Launch Studio -->
                    <Button Style="{StaticResource ActionCardStyle}" Command="{Binding LaunchRobloxStudioCommand, Mode=OneTime}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8" Background="#0CFFFFFF" Margin="0,0,14,0">
                                <TextBlock Text="◆" FontSize="14" Foreground="#A0A0A0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resources:Strings.LaunchMenu_LaunchRobloxStudio}" FontSize="14" FontWeight="Medium" Foreground="#E0E0E0" />
                                <TextBlock Text="Open development tools" FontSize="11" Foreground="#555555" Margin="0,1,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="→" FontSize="16" Foreground="#333333" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <!-- Settings -->
                    <Button Style="{StaticResource ActionCardStyle}" Command="{Binding LaunchSettingsCommand, Mode=OneTime}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8" Background="#0CFFFFFF" Margin="0,0,14,0">
                                <TextBlock Text="⚙" FontSize="16" Foreground="#A0A0A0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Static resources:Strings.LaunchMenu_ConfigureSettings}" FontSize="14" FontWeight="Medium" Foreground="#E0E0E0" />
                                <TextBlock Text="Themes, FastFlags, mods" FontSize="11" Foreground="#555555" Margin="0,1,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="→" FontSize="16" Foreground="#333333" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Footer links -->
                <Border Grid.Row="3" Margin="0,16,0,0" Padding="0,14" CornerRadius="0,0,16,16">
                    <Border.Background>
                        <SolidColorBrush Color="#FFFFFF" Opacity="0.02" />
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource RiftNavItemStyle}" Content="About" Padding="10,4" FontSize="11"
                                Foreground="#444444" Command="{Binding LaunchAboutCommand, Mode=OneTime}" />
                        <Ellipse Width="3" Height="3" Fill="#222222" VerticalAlignment="Center" Margin="4,0" />
                        <Button Style="{StaticResource RiftNavItemStyle}" Content="Wiki" Padding="10,4" FontSize="11"
                                Foreground="#444444" Command="models:GlobalViewModel.OpenWebpageCommand"
                                CommandParameter="https://github.com/riftstrap/riftstrap/wiki" />
                        <Ellipse Width="3" Height="3" Fill="#222222" VerticalAlignment="Center" Margin="4,0" />
                        <Button Style="{StaticResource RiftNavItemStyle}" Content="GitHub" Padding="10,4" FontSize="11"
                                Foreground="#444444" Command="models:GlobalViewModel.OpenWebpageCommand"
                                CommandParameter="https://github.com/riftstrap/riftstrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</base:WpfUiWindow>

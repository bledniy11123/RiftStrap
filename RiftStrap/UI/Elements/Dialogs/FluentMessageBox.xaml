<base:WpfUiWindow x:Class="RiftStrap.UI.Elements.Dialogs.FluentMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:RiftStrap.UI.Elements.Dialogs"
        xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
        xmlns:controls="clr-namespace:RiftStrap.UI.Elements.Controls"
        xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
        mc:Ignorable="d"
        Title="RiftStrap"
        d:DesignWidth="420"
        MinWidth="180"
        MaxWidth="420"
        Width="180"
        MinHeight="140"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Storyboard x:Key="Entrance">
            <DoubleAnimation Storyboard.TargetName="ContentRoot" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentSlide" Storyboard.TargetProperty="Y"
                             From="14" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="ContentRoot" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentSlide" />
        </Grid.RenderTransform>

        <Border CornerRadius="16" BorderThickness="1" BorderBrush="#12FFFFFF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#080808" Offset="0" />
                    <GradientStop Color="#0E0E11" Offset="0.5" />
                    <GradientStop Color="#080808" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top light bleed -->
                <Border Grid.Row="0" Grid.RowSpan="3" CornerRadius="16,16,0,0" Height="80" VerticalAlignment="Top" IsHitTestVisible="False" Opacity="0.5">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,-0.2" RadiusX="0.8" RadiusY="0.6">
                            <GradientStop Color="#0AFFFFFF" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Minimal title bar -->
                <Grid Grid.Row="0" Height="36">
                    <TextBlock Text="RiftStrap" FontSize="11" Foreground="#444444" VerticalAlignment="Center" Margin="16,0,0,0" />
                    <Button HorizontalAlignment="Right" Content="&#x2715;" FontSize="10" Foreground="#666666"
                            Width="28" Height="28" Margin="0,6,8,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Message content -->
                <Grid Grid.Row="1" Margin="20,4,20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image x:Name="IconImage" Grid.Column="0" RenderOptions.BitmapScalingMode="HighQuality"
                           Width="28" Height="28" Margin="0,0,14,0" VerticalAlignment="Top" />
                    <controls:MarkdownTextBlock x:Name="MessageTextBlock" Grid.Column="1"
                           VerticalAlignment="Center" TextWrapping="Wrap"
                           Foreground="#E0E0E0" FontSize="13" />
                </Grid>

                <!-- Buttons -->
                <Border Grid.Row="2" CornerRadius="0,0,16,16" Padding="16,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#06FFFFFF" Offset="0" />
                            <GradientStop Color="#0AFFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight" HorizontalAlignment="Right">
                        <Button x:Name="ButtonOne" MinWidth="80" Content="Button 1" Margin="0,0,0,0"
                                Style="{StaticResource RiftNavItemStyle}" Padding="16,8" FontSize="13" />
                        <Button x:Name="ButtonTwo" MinWidth="80" Margin="8,0,0,0" Content="Button 2"
                                Style="{StaticResource RiftNavItemStyle}" Padding="16,8" FontSize="13" />
                        <Button x:Name="ButtonThree" MinWidth="80" Margin="8,0,0,0" Content="Button 3"
                                Style="{StaticResource RiftNavItemStyle}" Padding="16,8" FontSize="13" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>

<base:WpfUiWindow x:Class="RiftStrap.UI.Elements.Dialogs.AddFastFlagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:RiftStrap.UI.Elements.Dialogs"
        xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
        xmlns:resources="clr-namespace:RiftStrap.Resources"
        xmlns:converters="clr-namespace:RiftStrap.UI.Converters"
        xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
        mc:Ignorable="d"
        Title="{x:Static resources:Strings.Dialog_AddFastFlag_Title}"
        MinHeight="0" Width="440" SizeToContent="Height" ResizeMode="NoResize"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowBackdropType="None" WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <ui:UiWindow.Resources>
        <converters:RangeConverter x:Key="ValidationConverter" From="0" />

        <Storyboard x:Key="Entrance">
            <DoubleAnimation Storyboard.TargetName="ContentRoot" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentSlide" Storyboard.TargetProperty="Y"
                             From="14" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </ui:UiWindow.Resources>

    <Grid x:Name="ContentRoot" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentSlide" />
        </Grid.RenderTransform>

        <Border CornerRadius="16" BorderThickness="1" BorderBrush="#12FFFFFF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#080808" Offset="0" />
                    <GradientStop Color="#0E0E11" Offset="0.5" />
                    <GradientStop Color="#080808" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top light bleed -->
                <Border Grid.Row="0" Grid.RowSpan="3" CornerRadius="16,16,0,0" Height="80" VerticalAlignment="Top" IsHitTestVisible="False" Opacity="0.5">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,-0.2" RadiusX="0.8" RadiusY="0.6">
                            <GradientStop Color="#0AFFFFFF" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Header -->
                <Grid Grid.Row="0" Height="44">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <TextBlock Text="&#x2691;" FontSize="14" Foreground="#666666" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Static resources:Strings.Dialog_AddFastFlag_Title}" FontSize="14" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Content="&#x2715;" FontSize="10" Foreground="#666666"
                            Width="28" Height="28" Margin="0,8,10,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Content -->
                <TabControl x:Name="Tabs" Grid.Row="1" Margin="18,0,18,18"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#FAFAFA">
                    <TabItem Header="{x:Static resources:Strings.Common_AddSingle}" Foreground="#A0A0A0">
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" MinWidth="80"
                                       Text="{x:Static resources:Strings.Common_Name}" Foreground="#888888" Margin="0,0,12,12" FontSize="13" />
                            <Border Grid.Row="0" Grid.Column="1" CornerRadius="8" Margin="0,0,0,12" Background="#1A1A1A" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                <TextBox Name="FlagNameTextBox"
                                         Background="Transparent" Foreground="#FAFAFA" BorderThickness="0" Padding="8,6" />
                            </Border>
                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" MinWidth="80"
                                       Text="{x:Static resources:Strings.Common_Value}" Foreground="#888888" FontSize="13" />
                            <Border Grid.Row="1" Grid.Column="1" CornerRadius="8" Background="#1A1A1A" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                <TextBox Name="FlagValueTextBox"
                                         Background="Transparent" Foreground="#FAFAFA" BorderThickness="0" Padding="8,6" />
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{x:Static resources:Strings.Common_ImportJson}" Foreground="#A0A0A0">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" CornerRadius="8" Margin="0,0,0,8" Background="#1A1A1A" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                <Grid>
                                    <TextBox x:Name="JsonTextBox" AcceptsTab="True" AcceptsReturn="True"
                                             MinHeight="80" MaxHeight="480"
                                             Background="Transparent" Foreground="#FAFAFA" BorderThickness="0"
                                             FontFamily="JetBrains Mono, Cascadia Code, Consolas" FontSize="12" Padding="8" />
                                    <TextBlock IsHitTestVisible="False" Margin="10,10,0,0" Foreground="#444444"
                                               FontFamily="JetBrains Mono, Cascadia Code, Consolas" FontSize="12"
                                               Text="{}{&#10;    &quot;FFlagDebugDisplayFPS&quot;: &quot;True&quot;&#10;}">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=JsonTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <rift:RiftButton Grid.Row="1" Content="{x:Static resources:Strings.Common_ImportFromFile}"
                                             Variant="Secondary" HorizontalAlignment="Stretch" Padding="0,10"
                                             Click="ImportButton_Click" />
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- Footer -->
                <Border Grid.Row="2" CornerRadius="0,0,16,16" Padding="18,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#06FFFFFF" Offset="0" />
                            <GradientStop Color="#0AFFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <rift:RiftButton MinWidth="90" Content="{x:Static resources:Strings.Common_OK}" Variant="Primary"
                                         Padding="16,8" Click="OKButton_Click">
                            <rift:RiftButton.Style>
                                <Style TargetType="{x:Type rift:RiftButton}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ElementName=Tabs, Path=SelectedIndex}" Value="0" />
                                                <Condition Binding="{Binding ElementName=FlagNameTextBox, Path=Text.Length, Converter={StaticResource ValidationConverter}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="IsEnabled" Value="True" />
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ElementName=Tabs, Path=SelectedIndex}" Value="1" />
                                                <Condition Binding="{Binding ElementName=JsonTextBox, Path=Text.Length, Converter={StaticResource ValidationConverter}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="IsEnabled" Value="True" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                    <Setter Property="IsEnabled" Value="False" />
                                </Style>
                            </rift:RiftButton.Style>
                        </rift:RiftButton>
                        <rift:RiftButton MinWidth="90" Margin="8,0,0,0" Content="{x:Static resources:Strings.Common_Cancel}"
                                         Variant="Ghost" Padding="16,8" IsCancel="True" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>

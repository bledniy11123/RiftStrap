<base:WpfUiWindow
    x:Class="RiftStrap.UI.Elements.Dialogs.AddCustomThemeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:RiftStrap.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:RiftStrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:RiftStrap.UI.ViewModels.Dialogs"
    xmlns:rift="clr-namespace:RiftStrap.UI.Controls.Rift"
    Title="Add Custom Theme"
    Width="480"
    MinHeight="0"
    d:DataContext="{d:DesignInstance viewmodels:AddCustomThemeViewModel,
                                     IsDesignTimeCreatable=True}"
    Background="Transparent"
    WindowStyle="None"
    AllowsTransparency="True"
    WindowBackdropType="None"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    mc:Ignorable="d">

    <Window.Resources>
        <Storyboard x:Key="Entrance">
            <DoubleAnimation Storyboard.TargetName="ContentRoot" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentSlide" Storyboard.TargetProperty="Y"
                             From="14" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="ContentRoot" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentSlide" />
        </Grid.RenderTransform>

        <Border CornerRadius="16" BorderThickness="1" BorderBrush="#12FFFFFF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#080808" Offset="0" />
                    <GradientStop Color="#0E0E11" Offset="0.5" />
                    <GradientStop Color="#080808" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top light bleed -->
                <Border Grid.Row="0" Grid.RowSpan="3" CornerRadius="16,16,0,0" Height="80" VerticalAlignment="Top" IsHitTestVisible="False" Opacity="0.5">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,-0.2" RadiusX="0.8" RadiusY="0.6">
                            <GradientStop Color="#0AFFFFFF" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Header -->
                <Grid Grid.Row="0" Height="44">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <TextBlock Text="&#x1F3A8;" FontSize="14" Foreground="#666666" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Static resources:Strings.CustomTheme_Add_Title}" FontSize="14" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Content="&#x2715;" FontSize="10" Foreground="#666666"
                            Width="28" Height="28" Margin="0,8,10,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Content -->
                <TabControl
                    x:Name="Tabs"
                    Grid.Row="1"
                    Margin="18,0,18,18"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#FAFAFA"
                    SelectedIndex="{Binding Path=SelectedTab, Mode=TwoWay}">
                    <TabItem Header="{x:Static resources:Strings.Common_CreateNew}" Foreground="#A0A0A0">
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid
                                Grid.Row="0"
                                Grid.ColumnSpan="2"
                                Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    MinWidth="100"
                                    VerticalAlignment="Center"
                                    Foreground="#888888"
                                    FontSize="13"
                                    Margin="0,0,12,0"
                                    Text="{x:Static resources:Strings.Common_Name}" />
                                <TextBox
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Background="#1A1A1A"
                                    Foreground="#FAFAFA"
                                    BorderBrush="#1AFFFFFF"
                                    Padding="8,6"
                                    Text="{Binding Path=Name, Mode=TwoWay}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Foreground="#AAAAAA"
                                    Text="{Binding Path=NameError, Mode=OneWay}"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap"
                                    Visibility="{Binding Path=NameErrorVisibility, Mode=OneWay}" />
                            </Grid>

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                MinWidth="100"
                                VerticalAlignment="Center"
                                Foreground="#888888"
                                FontSize="13"
                                Text="{x:Static resources:Strings.Common_Template}" />

                            <ComboBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Background="#1A1A1A"
                                Foreground="#FAFAFA"
                                BorderBrush="#1AFFFFFF"
                                ItemsSource="{Binding Path=Templates, Mode=OneTime}"
                                Text="{Binding Path=Template, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{x:Static resources:Strings.Common_Import}" Foreground="#A0A0A0">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                FontSize="14"
                                Foreground="#FAFAFA"
                                Text="{Binding Path=FilePath}"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Visibility="{Binding Path=FilePathVisibility}" />
                            <rift:RiftButton
                                Grid.Row="1"
                                Margin="0,4"
                                HorizontalAlignment="Stretch"
                                Padding="0,10"
                                Click="OnImportButtonClicked"
                                Content="{x:Static resources:Strings.Common_ImportFromFile}"
                                Variant="Secondary" />
                            <TextBlock
                                Grid.Row="2"
                                Foreground="#AAAAAA"
                                Text="{Binding Path=FileError}"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Visibility="{Binding Path=FileErrorVisibility}" />
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- Footer -->
                <Border Grid.Row="2" CornerRadius="0,0,16,16" Padding="18,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#06FFFFFF" Offset="0" />
                            <GradientStop Color="#0AFFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel
                        HorizontalAlignment="Right"
                        FlowDirection="LeftToRight"
                        Orientation="Horizontal">
                        <rift:RiftButton
                            MinWidth="90"
                            Content="{x:Static resources:Strings.Common_OK}"
                            Variant="Primary"
                            Padding="16,8"
                            Click="OnOkButtonClicked" />
                        <rift:RiftButton
                            MinWidth="90"
                            Margin="8,0,0,0"
                            Content="{x:Static resources:Strings.Common_Cancel}"
                            Variant="Ghost"
                            Padding="16,8"
                            IsCancel="True" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>
